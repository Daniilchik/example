         - name: hivemetastore
           image: "{{ coalesce .Values.hiveMetastore.image.registry .Values.global.image.registry }}/{{ .Values.hiveMetastore.image.repository }}:{{ .Values.hiveMetastore.image.tag }}"
           {{- include "ozone.containerSecurityContext" $ | nindent 10 }}
@@ -54,6 +68,12 @@ spec:
               value: /opt/hive/conf
             - name: DB_DRIVER
               value: postgres
+            {{- if .Values.fluentBit.enabled }}
+            - name: HIVE_LOG_DIR
+              value: {{ .Values.fluentBit.logDir | quote }}
+            - name: HADOOP_OPTS
+              value: "-Dlog4j2.debug=true"
+            {{- end }}
             {{- if and .Values.secman.enabled .Values.hiveMetastore.secman.dbPasswordKey }}
             - name: DB_PASSWORD_FILE
               value: /vault/secrets/db-password
@@ -83,6 +103,9 @@ spec:
           volumeMounts:
             - name: hive-conf
               mountPath: /opt/hive/conf
+            {{- if .Values.fluentBit.enabled }}
+            {{- include "ozone.fluentbit.logsMount" . | nindent 12 }}
+            {{- end }}
             {{- if .Values.global.security.kerberos.enabled }}
             - name: keytabs
               mountPath: {{ .Values.global.security.kerberos.keytabDir }}
@@ -106,6 +129,9 @@ spec:
           {{- end }}
 
       volumes:
+        {{- if .Values.fluentBit.enabled }}
+        {{- include "ozone.fluentbit.volumes" . | nindent 8 }}
+        {{- end }}
         # Projected volume merges the Ozone cluster config (core-site.xml, ozone-site.xml)
