diff --git a/helm-charts/ozone/templates/hivemetastore/configmap.yaml b/helm-charts/ozone/templates/hivemetastore/configmap.yaml
index 73923e6..4e6812e 100644
--- a/helm-charts/ozone/templates/hivemetastore/configmap.yaml
+++ b/helm-charts/ozone/templates/hivemetastore/configmap.yaml
@@ -8,6 +8,49 @@ metadata:
     {{- include "ozone.labels" . | nindent 4 }}
     app.kubernetes.io/component: hive-metastore
 data:
+  {{- if .Values.fluentBit.enabled }}
+  # Metastore log4j2 config — auto-discovered via classpath (HIVE_CONF_DIR is first).
+  # Writes to {{ .Values.fluentBit.logDir }}/hivemetastore.log so the fluent-bit sidecar
+  # can tail it. Console appender is kept for kubectl logs visibility.
+  log4j2.properties: |-
+    status = INFO
+    name = MetastoreLog4j2
+    packages = org.apache.hadoop.hive.ql.log
+
+    appenders = console, DRFA
+
+    appender.console.type = Console
+    appender.console.name = console
+    appender.console.target = SYSTEM_ERR
+    appender.console.layout.type = PatternLayout
+    appender.console.layout.pattern = %d{yy/MM/dd HH:mm:ss} [%t]: %p %c{2}: %m%n
+
+    appender.DRFA.type = RollingRandomAccessFile
+    appender.DRFA.name = DRFA
+    appender.DRFA.fileName = {{ .Values.fluentBit.logDir }}/hivemetastore.log
+    appender.DRFA.filePattern = {{ .Values.fluentBit.logDir }}/hivemetastore.%d{yyyy-MM-dd}-%i.log.gz
+    appender.DRFA.layout.type = PatternLayout
+    appender.DRFA.layout.pattern = %d{ISO8601} %-5p [%t]: %c{2} (%F:%L) - %m%n
+    appender.DRFA.policies.type = Policies
+    appender.DRFA.policies.time.type = TimeBasedTriggeringPolicy
+    appender.DRFA.policies.time.interval = 1
+    appender.DRFA.policies.size.type = SizeBasedTriggeringPolicy
+    appender.DRFA.policies.size.size = 64MB
+    appender.DRFA.strategy.type = DefaultRolloverStrategy
+    appender.DRFA.strategy.max = 5
+
+    loggers = DataNucleus, JPOX
+
+    rootLogger.level = INFO
+    rootLogger.appenderRef.console.ref = console
+    rootLogger.appenderRef.DRFA.ref = DRFA
+
+    logger.DataNucleus.name = DataNucleus
+    logger.DataNucleus.level = ERROR
+    logger.JPOX.name = JPOX
+    logger.JPOX.level = ERROR
+  {{- end }}
+
   hive-site.xml: |-
     <?xml version="1.0" encoding="UTF-8"?>
     <?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
diff --git a/helm-charts/ozone/templates/hivemetastore/deployment.yaml b/helm-charts/ozone/templates/hivemetastore/deployment.yaml
