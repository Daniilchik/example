+        - name: cli
+          image: "{{ .Values.global.image.registry }}/{{ tpl .Values.cli.image.repository . }}:{{ tpl .Values.cli.image.tag . }}"
+          {{- include "ozone.containerSecurityContext" $ | nindent 10 }}
+          imagePullPolicy: Always
