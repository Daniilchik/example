diff --git a/helm-charts/ozone/templates/istio/serviceentry.yaml b/helm-charts/ozone/templates/istio/serviceentry.yaml
index 2be2abd..e1f98b1 100644
--- a/helm-charts/ozone/templates/istio/serviceentry.yaml
+++ b/helm-charts/ozone/templates/istio/serviceentry.yaml
@@ -44,5 +44,30 @@ spec:
   resolution: DNS
   location: MESH_EXTERNAL
   {{- end }}
+{{- if and .Values.ranger.enabled .Values.ranger.policyAdminUrl }}
+{{- $rangerUrl := .Values.ranger.policyAdminUrl }}
+{{- $rangerHost := regexReplaceAll "^https?://" $rangerUrl "" | regexReplaceAll ":[0-9]+$" "" | regexReplaceAll "/.*$" "" }}
+{{- $rangerPort := 443 }}
+{{- if regexMatch ":[0-9]+" $rangerUrl }}
+{{- $rangerPort = $rangerUrl | regexFind ":[0-9]+" | trimPrefix ":" | int }}
+{{- end }}
+---
+apiVersion: networking.istio.io/v1beta1
+kind: ServiceEntry
+metadata:
+  name: {{ include "ozone.fullname" . }}-ranger-admin
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+spec:
+  hosts:
+    - {{ $rangerHost | quote }}
+  ports:
+    - number: {{ $rangerPort }}
+      name: https-ranger
+      protocol: HTTPS
+  resolution: DNS
+  location: MESH_EXTERNAL
+{{- end }}
 {{- end }}
 {{- end }}
\ No newline at end of file
