-// schemaInfo проверяет наличие схемы Hive Metastore в БД.
-func schemaInfo(classpath string, env []string) error {
-	return runJava(schemaToolMainClass, classpath, []string{"-dbType", "postgres", "-info"}, env)
+// findJdbcEndpoint читает hive-site.xml и возвращает host:port из ConnectionURL.
+func findJdbcEndpoint() (string, error) {
+	confDir := os.Getenv("HIVE_CONF_DIR")
+	if confDir == "" {
+		confDir = hiveHome + "/conf"
+	}
+	path := filepath.Join(confDir, "hive-site.xml")
+	data, err := os.ReadFile(path)
+	if err != nil {
+		return "", fmt.Errorf("read %s: %v", path, err)
+	}
+	type prop struct {
+		Name  string `xml:"name"`
+		Value string `xml:"value"`
+	}
+	type config struct {
+		Properties []prop `xml:"property"`
+	}
+	var c config
+	if err := xml.Unmarshal(data, &c); err != nil {
+		return "", fmt.Errorf("parse %s: %v", path, err)
+	}
+	var jdbcURL string
+	for _, p := range c.Properties {
+		if p.Name == jdbcURLProperty {
+			jdbcURL = strings.TrimSpace(p.Value)
+			break
+		}
+	}
+	if jdbcURL == "" {
+		return "", fmt.Errorf("%s not found in hive-site.xml", jdbcURLProperty)
+	}
+	// jdbc:postgresql://host:port/db?...
+	re := regexp.MustCompile(`^jdbc:[^:]+://([^/?]+)`)
+	m := re.FindStringSubmatch(jdbcURL)
+	if len(m) < 2 {
+		return "", fmt.Errorf("cannot parse host:port from %s", jdbcURL)
+	}
+	hp := m[1]
+	if !strings.Contains(hp, ":") {
+		hp += ":5432"
+	}
+	return hp, nil
 }

