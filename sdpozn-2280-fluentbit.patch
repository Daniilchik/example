diff --git a/helm-charts/ozone/templates/fluentbit/configmap.yaml b/helm-charts/ozone/templates/fluentbit/configmap.yaml
new file mode 100644
index 0000000..3affc79
--- /dev/null
+++ b/helm-charts/ozone/templates/fluentbit/configmap.yaml
@@ -0,0 +1,82 @@
+{{- if .Values.fluentBit.enabled }}
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: fluent-bit-ozone-config
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: fluent-bit-config
+data:
+  fluent-bit.conf: |-
+    [SERVICE]
+        Config_Watch      On
+        Daemon            Off
+        Flush             1
+        HTTP_Listen       0.0.0.0
+        HTTP_Port         {{ .Values.fluentBit.fluentMetricsPort }}
+        HTTP_Server       On
+        Log_Level         info
+
+    [INPUT]
+        Name              tail
+        Tag               tech
+        Path              ${FLUENTBIT_TECH_LOG_PATH}
+        DB                /tmp/fluent-bit-tech.db
+        DB.Sync           Normal
+        Path_Key          source_file
+        Mem_Buf_Limit     5MB
+        Skip_Long_Lines   On
+        Refresh_Interval  10
+
+    [INPUT]
+        Name              tail
+        Tag               audit
+        Path              ${FLUENTBIT_AUDIT_LOG_PATH}
+        DB                /tmp/fluent-bit-audit.db
+        DB.Sync           Normal
+        Path_Key          source_file
+        Mem_Buf_Limit     5MB
+        Skip_Long_Lines   On
+        Refresh_Interval  10
+
+    # ${HOSTNAME} is set by container runtime to the pod name.
+    # k8s downward API ($(POD_NAME)) is not used because fluent-bit fails
+    # to expand env vars sourced from valueFrom.fieldRef on this image.
+    [FILTER]
+        Name           modify
+        Match          *
+        Add            app_id {{ .Values.fluentBit.appId | quote }}
+        Add            type_id "Audit"
+        Add            component ${FLUENTBIT_COMPONENT}
+        Add            pod_name ${HOSTNAME}
+        Add            namespace ${POD_NAMESPACE}
+        Rename         log message
+
+    [FILTER]
+        Name    lua
+        Match   *
+        script  /fluent-bit/etc/enrich.lua
+        call    prepend_meta
+
+    [OUTPUT]
+        Name       http
+        Match      *
+        Host       {{ .Values.fluentBit.restlogsHost }}
+        Port       {{ .Values.fluentBit.restlogsPort }}
+        tls        On
+        {{- if .Values.fluentBit.caCertSecret }}
+        tls.verify On
+        tls.ca_file /fluent-bit/tls/{{ .Values.fluentBit.caCertKey | default "ca.crt" }}
+        {{- else }}
+        tls.verify Off
+        {{- end }}
+        Format     json
+
+  enrich.lua: |
+    function prepend_meta(tag, ts, record)
+        local prefix = "[cluster=" .. (record["namespace"] or "") .. " pod=" .. (record["pod_name"] or "") .. "] "
+        record["message"] = prefix .. (record["message"] or "")
+        return 1, ts, record
+    end
+{{- end }}
