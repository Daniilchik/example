index b525c59..7affc15 100644
--- a/helm-charts/ozone/templates/_helpers.tpl
+++ b/helm-charts/ozone/templates/_helpers.tpl
@@ -242,3 +242,84 @@ Usage: {{- include "ozone.secmanLabels" . | nindent 8 }}
 secman-injector: enabled
 {{- end }}
 {{- end -}}
+
+{{/*
+Fluent-bit sidecar container.
+Tails the component's tech log and (optionally) audit log from the shared
+emptyDir volume and ships them to the external collector.
+
+Args (dict):
+  ctx        — root context ($)
+  component  — component name used as `component` label on log events (om, scm, datanode, s3g, recon)
+  techPath   — absolute path of the tech log file to tail (e.g. /var/log/ozone/om.log)
+  auditPath  — absolute path of the audit log file to tail; pass "" if the component has no audit log
+
+Usage:
+  {{- include "ozone.fluentbit.container" (dict "ctx" $ "component" "om" "techPath" "/var/log/ozone/om.log" "auditPath" "/var/log/ozone/om-audit.log") | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.container" -}}
+{{- $ctx := .ctx -}}
+- name: fluent-bit
+  image: {{ $ctx.Values.fluentBit.image }}
+  imagePullPolicy: {{ $ctx.Values.fluentBit.imagePullPolicy | default "IfNotPresent" }}
+  env:
+    - name: FLUENTBIT_COMPONENT
+      value: {{ .component | quote }}
+    - name: FLUENTBIT_TECH_LOG_PATH
+      value: {{ .techPath | quote }}
+    - name: FLUENTBIT_AUDIT_LOG_PATH
+      value: {{ .auditPath | default "/var/log/ozone/.no-audit" | quote }}
+  ports:
+    - containerPort: {{ $ctx.Values.fluentBit.fluentMetricsPort }}
+      name: fb-metrics
+      protocol: {{ $ctx.Values.fluentBit.fluentMetricsProtocol | default "TCP" }}
+  {{- include "ozone.containerSecurityContext" $ctx | nindent 2 }}
+  {{- with $ctx.Values.fluentBit.resources }}
+  resources:
+    {{- toYaml . | nindent 4 }}
+  {{- end }}
+  volumeMounts:
+    - name: fluent-bit-config
+      mountPath: /fluent-bit/etc/
+    - name: fluent-bit-tmp
+      mountPath: /tmp
+    - name: ozone-logs
+      mountPath: /var/log/ozone
+    {{- if $ctx.Values.fluentBit.caCertSecret }}
+    - name: fluent-bit-ca
+      mountPath: /fluent-bit/tls
+      readOnly: true
+    {{- end }}
+{{- end -}}
+
+{{/*
+Volumes required by fluent-bit sidecar + the shared log dir.
+Usage:
+  {{- include "ozone.fluentbit.volumes" $ | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.volumes" -}}
+- name: fluent-bit-config
+  configMap:
+    name: fluent-bit-ozone-config
+- name: fluent-bit-tmp
+  emptyDir: {}
+- name: ozone-logs
+  emptyDir: {}
+{{- if .Values.fluentBit.caCertSecret }}
+- name: fluent-bit-ca
+  secret:
+    secretName: {{ .Values.fluentBit.caCertSecret | quote }}
+{{- end }}
+{{- end -}}
+
+{{/*
+VolumeMount for the main container, pointing at the shared log dir.
+The main Ozone container must write to /var/log/ozone so fluent-bit
+can tail those files from its own mount of the same emptyDir.
+Usage:
+  {{- include "ozone.fluentbit.logsMount" $ | nindent 12 }}
+*/}}
+{{- define "ozone.fluentbit.logsMount" -}}
+- name: ozone-logs
+  mountPath: /var/log/ozone
+{{- end -}}
