+spec:
+  host: {{ .Values.fluentBit.restlogsHost | quote }}
+  trafficPolicy:
+    tls:
+      mode: DISABLE
+{{- end }}
 ---
 apiVersion: networking.istio.io/v1beta1
 kind: ServiceEntry
