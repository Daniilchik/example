index b525c59..0d6fb8c 100644
--- a/helm-charts/ozone/templates/_helpers.tpl
+++ b/helm-charts/ozone/templates/_helpers.tpl
@@ -242,3 +242,137 @@ Usage: {{- include "ozone.secmanLabels" . | nindent 8 }}
 secman-injector: enabled
 {{- end }}
 {{- end -}}
+
+{{/*
+Fluent-bit sidecar container.
+
+Tails <logDir>/<component>.log (and <logDir>/<component>-audit.log when
+the component has an audit logger) from the shared emptyDir and ships
+them to the external collector.
+
+Args (dict):
+  ctx        — root context ($)
+  component  — short component name (om, scm, datanode, s3g, recon).
+               File names are derived from the component map below.
+
+Usage:
+  {{- include "ozone.fluentbit.container" (dict "ctx" $ "component" "om") | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.container" -}}
+{{- $ctx := .ctx -}}
+{{- $logDir := $ctx.Values.fluentBit.logDir -}}
+{{- $component := .component -}}
+{{- $auditPrefix := index (dict "om" "om" "scm" "scm" "datanode" "dn" "s3g" "s3g") $component -}}
+- name: fluent-bit
+  image: {{ $ctx.Values.fluentBit.image }}
+  imagePullPolicy: {{ $ctx.Values.fluentBit.imagePullPolicy | default "IfNotPresent" }}
+  env:
+    - name: FLUENTBIT_COMPONENT
+      value: {{ $component | quote }}
+    - name: FLUENTBIT_TECH_LOG_PATH
+      value: {{ printf "%s/%s.log" $logDir $component | quote }}
+    - name: FLUENTBIT_AUDIT_LOG_PATH
+      {{- if $auditPrefix }}
+      value: {{ printf "%s/%s-audit.log" $logDir $auditPrefix | quote }}
+      {{- else }}
+      value: {{ printf "%s/.no-audit" $logDir | quote }}
+      {{- end }}
+    - name: POD_NAMESPACE
+      value: {{ include "ozone.namespace" $ctx | quote }}
+  ports:
+    - containerPort: {{ $ctx.Values.fluentBit.fluentMetricsPort }}
+      name: fb-metrics
+      protocol: {{ $ctx.Values.fluentBit.fluentMetricsProtocol | default "TCP" }}
+  livenessProbe:
+    httpGet:
+      path: /api/v1/health
+      port: fb-metrics
+    initialDelaySeconds: 10
+    periodSeconds: 30
+  {{- include "ozone.containerSecurityContext" $ctx | nindent 2 }}
+  {{- with $ctx.Values.fluentBit.resources }}
+  resources:
+    {{- toYaml . | nindent 4 }}
+  {{- end }}
+  volumeMounts:
+    - name: fluent-bit-config
+      mountPath: /fluent-bit/etc/
+    - name: fluent-bit-tmp
+      mountPath: /tmp
+    - name: ozone-logs
+      mountPath: {{ $logDir }}
+    {{- if $ctx.Values.fluentBit.caCertSecret }}
+    - name: fluent-bit-ca
+      mountPath: /fluent-bit/tls
+      readOnly: true
+    {{- end }}
+{{- end -}}
+
+{{/*
+Volumes required by fluent-bit sidecar + the shared log dir.
+Usage:
+  {{- include "ozone.fluentbit.volumes" $ | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.volumes" -}}
+- name: fluent-bit-config
+  configMap:
+    name: fluent-bit-ozone-config
+- name: fluent-bit-tmp
+  emptyDir: {}
+- name: ozone-logs
+  emptyDir: {}
+{{- if .Values.fluentBit.caCertSecret }}
+- name: fluent-bit-ca
+  secret:
+    secretName: {{ .Values.fluentBit.caCertSecret | quote }}
+{{- end }}
+{{- end -}}
+
+{{/*
+VolumeMount for the main Ozone container, pointing at the shared log dir.
+The main container must write to fluentBit.logDir so fluent-bit can tail
+those files from its own mount of the same emptyDir.
+Usage:
+  {{- include "ozone.fluentbit.logsMount" $ | nindent 12 }}
+*/}}
+{{- define "ozone.fluentbit.logsMount" -}}
+- name: ozone-logs
+  mountPath: {{ .Values.fluentBit.logDir }}
+{{- end -}}
+
+{{/*
+Log4j2 sys-prop suffix for OZONE_OPTS. Builds the comma-separated
+log4j.configurationFile list (main + per-component audit) and enables the
+async logger context selector required by upstream Ozone.
+
+Recon has no audit logger, so its argument list omits the audit config.
+
+Args (dict):
+  ctx        — root context ($)
+  component  — short component name (om, scm, datanode, s3g, recon)
+
+Usage:
+  -Dhadoop.log.dir=... {{ include "ozone.fluentbit.log4jOpts" (dict "ctx" $ "component" "om") }}
+*/}}
+{{/*
+Egress host entry for the fluent-bit collector.
+Used inside Sidecar.egress[0].hosts to allow Envoy to send traffic
+to the external collector when istio is enabled.
+Usage:
+  {{- include "ozone.fluentbit.istioEgress" . | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.istioEgress" -}}
+{{- if and .Values.fluentBit.enabled .Values.fluentBit.restlogsHost -}}
+- "./{{ .Values.fluentBit.restlogsHost }}"
+{{- end -}}
+{{- end -}}
+
+{{- define "ozone.fluentbit.log4jOpts" -}}
+{{- $confDir := "/ozone/etc/hadoop" -}}
+{{- $auditPrefix := index (dict "om" "om" "scm" "scm" "datanode" "dn" "s3g" "s3g") .component -}}
+{{- $configs := list (printf "%s/log4j2.xml" $confDir) -}}
+{{- if $auditPrefix -}}
+  {{- $configs = append $configs (printf "%s/%s-audit-log4j2.xml" $confDir $auditPrefix) -}}
+{{- end -}}
+-Dhadoop.log.dir={{ .ctx.Values.fluentBit.logDir }} -Dhadoop.log.file={{ .component }}.log -Dlog4j.configurationFile={{ join "," $configs }} -Dlog4j2.contextSelector=org.apache.logging.log4j.core.async.AsyncLoggerContextSelector
+{{- end -}}
