+# Fluent-bit sidecar — ships /var/log/ozone/<component>.log and <component>-audit.log
+# (where applicable) to the external collector via http+TLS.
+# Override image/appId/restlogsHost per environment in values-<env>.yaml.
+fluentBit:
+  enabled: false
+  image: ""
+  imagePullPolicy: Always
+  appId: ""
+  # External collector endpoint
+  restlogsHost: ""
+  restlogsPort: 44443
+  # Local fluent-bit metrics endpoint inside the pod
+  fluentMetricsPort: 2200
+  fluentMetricsProtocol: TCP
+  # Optional collector CA cert: name of a k8s Secret containing the PEM under caCertKey.
+  # When unset, TLS is on but verification is off (suitable for dev only).
+  caCertSecret: ""
+  caCertKey: ca.crt
+  # Where Ozone services write their log files. Same path is mounted into
+  # the fluent-bit sidecar so it can tail them.
+  logDir: /var/log/ozone
+  resources:
+    requests:
+      cpu: 20m
+      memory: 128Mi
+    limits:
+      cpu: 100m
+      memory: 256Mi
