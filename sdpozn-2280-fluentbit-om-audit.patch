-      <?xml version="1.0" encoding="UTF-8"?>
-      <Configuration status="WARN">
-          <Properties>
-              <Property name="hadoop.log.dir">${sys:hadoop.log.dir:-/var/log/ozone}</Property>
-              <Property name="hostName">${hostName}</Property>
-          </Properties>
-
-          <Appenders>
-              <!-- Uncomment following section to enable logging to console appender also
-              <Console name="STDOUT" target="SYSTEM_OUT">
-                  <PatternLayout pattern="%d{DEFAULT} | %-5level | %c{1} | %msg | %throwable{3} %n"/>
-              </Console>
-              -->
-
-              <RollingFile name="RollingFileOMAudit" fileName="${hadoop.log.dir}/om-audit-${hostName}.log" filePattern="${hadoop.log.dir}/om-audit-${hostName}-%d{yyyy-MM-dd-HH-mm-ss}-%i.log.gz">
-                  <PatternLayout pattern="%d{DEFAULT} | %-5level | %c{1} | %msg | %throwable{3} %n"/>
-                  <Policies>
-                      <TimeBasedTriggeringPolicy interval="86400"/>
-                      <SizeBasedTriggeringPolicy size="64MB"/>
-                  </Policies>
-                  <DefaultRolloverStrategy>
-                      <Delete basePath="${hadoop.log.dir}" maxDepth="1">
-                          <IfFileName glob="om-audit-*.log.gz"/>
-                          <IfLastModified age="30d"/>
-                      </Delete>
-                  </DefaultRolloverStrategy>
-                  <Filters>
-                      <MarkerFilter marker="READ" onMatch="NEUTRAL" onMismatch="NEUTRAL"/>
-                      <MarkerFilter marker="WRITE" onMatch="NEUTRAL" onMismatch="NEUTRAL"/>
-                  </Filters>
-              </RollingFile>
-          </Appenders>
-
-          <Loggers>
-              <AsyncLogger name="OMAudit" level="INFO" includeLocation="true" additivity="false">
-                  <AppenderRef ref="RollingFileOMAudit"/>
-
-                  <!-- Uncomment following section to enable logging to console appender also
-                  <AppenderRef ref="STDOUT"/>
-                  -->
-              </AsyncLogger>
-          </Loggers>
-      </Configuration>
 
