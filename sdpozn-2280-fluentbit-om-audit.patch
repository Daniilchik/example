diff --git a/helm-charts/ozone/templates/_helpers.tpl b/helm-charts/ozone/templates/_helpers.tpl
index 579fdd6..f1e2083 100644
--- a/helm-charts/ozone/templates/_helpers.tpl
+++ b/helm-charts/ozone/templates/_helpers.tpl
@@ -198,3 +198,73 @@ Usage: {{- include "ozone.secmanLabels" . | nindent 8 }}
 secman-injector: enabled
 {{- end }}
 {{- end -}}
+
+{{/*
+Fluent-bit sidecar container spec.
+Expects a dict with:
+  ctx        — root context ($)
+  component  — short component name used as `component` label on log events (om, scm, datanode, s3g, recon)
+  auditPath  — absolute path (or glob) of the audit log file to tail
+Usage:
+  {{- include "ozone.fluentbit.container" (dict "ctx" $ "component" "om" "auditPath" "/var/log/ozone/om-audit.log") | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.container" -}}
+{{- $ctx := .ctx -}}
+- name: fluentbit
+  image: {{ $ctx.Values.fluentBit.image }}
+  imagePullPolicy: {{ $ctx.Values.fluentBit.imagePullPolicy | default "Always" }}
+  env:
+    - name: FLUENTBIT_COMPONENT
+      value: {{ .component | quote }}
+    - name: FLUENTBIT_TECH_LOG_PATH
+      value: /var/log/ozone/hadoop.log
+    - name: FLUENTBIT_AUDIT_LOG_PATH
+      value: {{ .auditPath | quote }}
+    - name: FLUENTBIT_DB_PATH
+      value: /var/log/ozone/fluent-bit.db
+  ports:
+    - containerPort: {{ $ctx.Values.fluentBit.fluentMetricsPort }}
+      name: metrics
+      protocol: {{ $ctx.Values.fluentBit.fluentMetricsProtocol }}
+  resources:
+    limits:
+      cpu: {{ $ctx.Values.fluentBit.resources.limits.cpu | default "20m" }}
+      memory: {{ $ctx.Values.fluentBit.resources.limits.memory | default "128Mi" }}
+    requests:
+      cpu: {{ $ctx.Values.fluentBit.resources.requests.cpu | default "20m" }}
+      memory: {{ $ctx.Values.fluentBit.resources.requests.memory | default "128Mi" }}
+  {{- include "ozone.containerSecurityContext" $ctx | nindent 2 }}
+  volumeMounts:
+    - mountPath: /fluent-bit/etc/
+      name: fluent-bit-ozone-config
+    - mountPath: /tmp
+      name: fluent-bit-tmp
+    - mountPath: /var/log/ozone
+      name: ozone-logs
+{{- end -}}
+
+{{/*
+Volumes required for fluent-bit sidecar + shared log dir.
+Usage:
+  {{- include "ozone.fluentbit.volumes" $ | nindent 8 }}
+*/}}
+{{- define "ozone.fluentbit.volumes" -}}
+- name: fluent-bit-ozone-config
+  configMap:
+    name: fluent-bit-ozone-config
+- name: fluent-bit-tmp
+  emptyDir: {}
+- name: ozone-logs
+  emptyDir: {}
+{{- end -}}
+
+{{/*
+VolumeMount for main container pointing at shared log dir.
+Main container must write to /var/log/ozone so fluent-bit can tail from there.
+Usage:
+  {{- include "ozone.fluentbit.logsMount" $ | nindent 12 }}
+*/}}
+{{- define "ozone.fluentbit.logsMount" -}}
+- name: ozone-logs
+  mountPath: /var/log/ozone
+{{- end -}}
