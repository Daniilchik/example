diff --color --color=never -ruN /tmp/empty-knox-base/conf/topologies/sdpozone.xml component-knox-sdphadoop/conf/topologies/sdpozone.xml
--- /tmp/empty-knox-base/conf/topologies/sdpozone.xml	1970-01-01 03:00:00
+++ component-knox-sdphadoop/conf/topologies/sdpozone.xml	2026-05-15 05:03:41
@@ -0,0 +1,58 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<!--
+  SDP Ozone topology — единая точка входа для всех Ozone-сервисов через Knox.
+
+  URLs после деплоя:
+    https://<knox-host>:8443/gateway/sdpozone/recon/   → Ozone Recon UI (port 9888)
+    https://<knox-host>:8443/gateway/sdpozone/scm/     → SCM UI (опционально)
+    https://<knox-host>:8443/gateway/sdpozone/om/      → OM UI (опционально)
+
+  AuthN/AuthZ:
+    На текущий момент — ShiroProvider с anonymous-доступом (для DEV/IFT).
+    Для PROD заменяется через ConfigMap на LDAP/Kerberos.
+
+  Конкретные backend-URL-ы перекрываются в Helm-чарте через ConfigMap.
+-->
+<topology>
+    <gateway>
+        <provider>
+            <role>authentication</role>
+            <name>ShiroProvider</name>
+            <enabled>true</enabled>
+            <param>
+                <name>sessionTimeout</name>
+                <value>30</value>
+            </param>
+            <param>
+                <name>main.invalidRequest</name>
+                <value>org.apache.shiro.web.filter.InvalidRequestFilter</value>
+            </param>
+            <param>
+                <name>main.invalidRequest.blockNonAscii</name>
+                <value>true</value>
+            </param>
+            <param>
+                <name>urls./**</name>
+                <value>anon</value>
+            </param>
+        </provider>
+
+        <provider>
+            <role>identity-assertion</role>
+            <name>Default</name>
+            <enabled>true</enabled>
+        </provider>
+
+        <provider>
+            <role>hostmap</role>
+            <name>static</name>
+            <enabled>true</enabled>
+        </provider>
+    </gateway>
+
+    <!-- Custom service: Ozone Recon UI proxy -->
+    <service>
+        <role>RECON</role>
+        <url>http://recon:9888</url>
+    </service>
+</topology>
diff --color --color=never -ruN /tmp/empty-knox-base/docker/Dockerfile component-knox-sdphadoop/docker/Dockerfile
--- /tmp/empty-knox-base/docker/Dockerfile	1970-01-01 03:00:00
+++ component-knox-sdphadoop/docker/Dockerfile	2026-05-15 05:04:59
@@ -0,0 +1,103 @@
+# ── Stage 1: Go entrypoint ──────────────────────────────────────────────────
+FROM docker-dev.registry-ci.delta.sbrf.ru/ci04674694/ci04674694/golang:1.21-alpine AS go-builder
+
+WORKDIR /build
+COPY docker/knox-entrypoint.go .
+RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
+    go build -ldflags="-s -w" -trimpath -o knox-entrypoint knox-entrypoint.go
+
+# ── Stage 2: RPM extraction ─────────────────────────────────────────────────
+FROM docker-dev.registry-ci.delta.sbrf.ru/ci04675739/ci04675739/openjdk-8-runtime:8.10.8-se AS builder
+
+# Apache Knox RPM (URL передаётся через --build-arg в Jenkinsfile)
+ARG KNOX_RPM_URL
+RUN test -n "$KNOX_RPM_URL" || (echo "ERROR: KNOX_RPM_URL is required" && exit 1)
+
+RUN yum -y install cpio
+
+WORKDIR /knox-rpm-extract
+
+# Install Knox
+RUN curl -fkSL "$KNOX_RPM_URL" -o knox.rpm
+
+# Распаковка RPM → /opt/knox.
+# В SDP-стеке Knox обычно лежит по пути /usr/sdp/<version>/knox.
+# Берём всё содержимое и переносим в knoxrootfs, нормализуем пути в bin/.
+RUN set -e && \
+    mkdir -p rootfs && \
+    rpm2cpio knox.rpm | cpio -idmv -D rootfs && \
+    SRC=$(find rootfs/usr/sdp/ -maxdepth 2 -type d -name knox) && \
+    COUNT=$(echo "$SRC" | wc -l) && \
+    [ "$COUNT" -eq 1 ] || { echo "ERROR: There MUST be only one stack version in extracted Knox rootfs"; exit 1; } && \
+    mkdir -p knoxrootfs && \
+    find "$SRC/" -mindepth 1 -maxdepth 1 -exec mv {} knoxrootfs/ \; && \
+    if [ -f knoxrootfs/bin/gateway.sh ]; then \
+        sed -i -e 's|/usr/sdp/[^/]*/knox|/opt/knox|g' knoxrootfs/bin/gateway.sh; \
+    fi && \
+    if [ -f knoxrootfs/bin/knoxcli.sh ]; then \
+        sed -i -e 's|/usr/sdp/[^/]*/knox|/opt/knox|g' knoxrootfs/bin/knoxcli.sh; \
+    fi
+
+# ── Stage 3: Collect runtime dependencies ───────────────────────────────────
+FROM docker-dev.registry-ci.delta.sbrf.ru/ci04675739/ci04675739/openjdk-8-runtime:8.10.8-se AS extractor
+
+# Хост-инструменты, нужные только на этапе сбора .so:
+# - ncurses: tput / less / etc — может вызываться знаниями Knox CLI
+# - krb5-libs/krb5-workstation: librарии Kerberos и kinit (для SPNEGO в Knox)
+RUN yum install -y nc ncurses krb5-libs krb5-workstation
+
+# DoD: пользователь knox с UID 10001
+RUN groupadd -g 10001 knox && useradd -u 10001 -g knox knox
+
+COPY --from=builder /knox-rpm-extract/knoxrootfs /opt/knox
+
+RUN install -d -o knox -g knox -m 0755 /var/log/knox && \
+    install -d -o knox -g knox -m 0755 /etc/knox/conf && \
+    install -d -o knox -g knox -m 0755 /etc/knox/conf/topologies && \
+    install -d -o knox -g knox -m 0755 /etc/knox/conf/services && \
+    install -d -o knox -g knox -m 0700 /var/lib/knox/data
+
+# Дефолтные конфиги: gateway-site.xml + topology для проксирования Recon.
+# Конкретные значения (URLs, auth provider) перетираются ConfigMap-ом в k8s.
+COPY --chown=knox:knox conf/gateway-site.xml /etc/knox/conf/gateway-site.xml
+COPY --chown=knox:knox conf/topologies/sdpozone.xml /etc/knox/conf/topologies/sdpozone.xml
+
+COPY docker/collect-deps.sh /usr/local/bin/collect-deps.sh
+RUN chmod +x /usr/local/bin/collect-deps.sh && \
+    /usr/local/bin/collect-deps.sh /rootfs
+
+RUN cp -aL /usr/lib/jvm/ /usr/lib/jvm-resolved/
+
+# ── Stage 4: Distroless runtime ─────────────────────────────────────────────
+FROM scratch
+
+# Minimal OS runtime (libc, ssl, nss, kerberos, timezone, /etc/passwd с knox UID 10001)
+COPY --from=extractor /rootfs/ /
+
+# JVM
+COPY --from=extractor /usr/lib/jvm-resolved/ /usr/lib/jvm/
+
+# Knox
+COPY --from=extractor --chown=10001:10001 /opt/knox/ /opt/knox/
+
+# Конфигурация и runtime-каталоги. /var/lib/knox/data в k8s будет emptyDir.
+COPY --from=extractor --chown=10001:10001 /etc/knox/ /etc/knox/
+COPY --from=extractor --chown=10001:10001 /var/log/knox/ /var/log/knox/
+COPY --from=extractor --chown=10001:10001 /var/lib/knox/ /var/lib/knox/
+
+# Go entrypoint (заменяет /opt/knox/bin/gateway.sh)
+COPY --from=go-builder --chown=10001:10001 /build/knox-entrypoint /opt/knox/bin/knox-entrypoint
+
+ENV JAVA_HOME=/usr/lib/jvm/jre-1.8.0-openjdk \
+    KNOX_HOME=/opt/knox \
+    KNOX_CONF_DIR=/etc/knox/conf \
+    KNOX_DATA_DIR=/var/lib/knox/data \
+    KNOX_LOG_DIR=/var/log/knox \
+    KNOX_PID_DIR=/var/run/knox
+
+USER 10001
+
+EXPOSE 8443
+
+ENTRYPOINT ["/opt/knox/bin/knox-entrypoint"]
+CMD ["gateway"]
diff --color --color=never -ruN /tmp/empty-knox-base/docker/collect-deps.sh component-knox-sdphadoop/docker/collect-deps.sh
--- /tmp/empty-knox-base/docker/collect-deps.sh	1970-01-01 03:00:00
+++ component-knox-sdphadoop/docker/collect-deps.sh	2026-05-15 05:02:16
@@ -0,0 +1,181 @@
+#!/bin/bash
+set -euo pipefail
+
+ROOTFS="${1:-/rootfs}"
+mkdir -p "$ROOTFS"
+
+# ── Вспомогательные функции ─────────────────────────────────────────────────
+
+# Копирует файл в ROOTFS, сохраняя путь. Разыменовывает один уровень симлинков.
+copy_file() {
+    local src="$1"
+    [ -e "$src" ] || return 0
+    local real; real="$(readlink -f "$src")"
+    local dest_dir="${ROOTFS}$(dirname "$real")"
+    mkdir -p "$dest_dir"
+    [ -f "${dest_dir}/$(basename "$real")" ] || cp -p "$real" "$dest_dir/"
+    if [ -L "$src" ] && [ "$src" != "$real" ]; then
+        local link_dir="${ROOTFS}$(dirname "$src")"
+        local link_name; link_name="$(basename "$src")"
+        mkdir -p "$link_dir"
+        [ -e "${link_dir}/${link_name}" ] || ln -sf "$real" "${link_dir}/${link_name}"
+    fi
+}
+
+# Копирует бинарник и все его динамические зависимости (.so).
+copy_with_deps() {
+    local bin="$1"
+    local real; real="$(readlink -f "$bin")"
+    copy_file "$bin"
+    ldd "$real" 2>/dev/null | while read -r line; do
+        local lib
+        lib="$(echo "$line" | awk '/=>/ {print $3}')"
+        [ -z "$lib" ] && lib="$(echo "$line" | awk 'NF==2 && /^\// {print $1}')"
+        [ -z "$lib" ] || [ "$lib" = "not" ] && continue
+        [ -f "$lib" ] || continue
+        copy_file "$lib"
+    done
+}
+
+# ── 1. Java ──────────────────────────────────────────────────────────────────
+echo ">>> Java binary + dynamic deps"
+JAVA_REAL="$(readlink -f "$(which java)")"
+copy_with_deps "$JAVA_REAL"
+
+mkdir -p "${ROOTFS}/usr/bin"
+[ -e "${ROOTFS}/usr/bin/java" ] || ln -sf "$JAVA_REAL" "${ROOTFS}/usr/bin/java"
+
+# ── 2. JVM-внутренние .so (libjvm.so, libjava.so, …) ────────────────────────
+echo ">>> JVM internal libraries"
+JAVA_HOME_PROP=$(java -XshowSettings:property -version 2>&1 \
+    | awk -F'=' '/java\.home/ {gsub(/ /,"",$2); print $2; exit}')
+
+if [ -z "$JAVA_HOME_PROP" ] || [ ! -d "$JAVA_HOME_PROP" ]; then
+    JVM_BIN_DIR="$(dirname "$JAVA_REAL")"
+    JVM_ROOT="$(dirname "$JVM_BIN_DIR")"
+    for candidate in "${JVM_ROOT}/jre" "${JVM_ROOT}"; do
+        if [ -d "${candidate}/lib" ]; then
+            JAVA_HOME_PROP="${candidate}"
+            break
+        fi
+    done
+fi
+
+JVM_LIB_DIR="${JAVA_HOME_PROP}/lib"
+echo "  JVM home: ${JAVA_HOME_PROP}"
+echo "  JVM lib dir: ${JVM_LIB_DIR}"
+
+mkdir -p "${ROOTFS}${JVM_LIB_DIR}"
+cp -r "${JVM_LIB_DIR}/." "${ROOTFS}${JVM_LIB_DIR}/"
+
+find "${JVM_LIB_DIR}" -name "*.so*" -type f 2>/dev/null | while read -r sofile; do
+    ldd "$sofile" 2>/dev/null | awk '/=>/ {print $3}' | while read -r lib; do
+        [ -f "$lib" ] || continue
+        copy_file "$lib"
+    done
+done
+
+# ── 3. C++ runtime (libstdc++, libgcc_s) ─────────────────────────────────────
+# Некоторые JNI-нативки используют libstdc++; копируем явно — ldd на java их не видит.
+echo ">>> C++ runtime libraries"
+for cpplib in \
+    /lib64/libstdc++.so* /usr/lib64/libstdc++.so* /usr/lib/libstdc++.so* \
+    /lib64/libgcc_s.so*  /usr/lib64/libgcc_s.so*  /usr/lib/libgcc_s.so*; do
+    [ -f "$cpplib" ] || continue
+    copy_file "$cpplib"
+    ldd "$cpplib" 2>/dev/null | awk '/=>/ {print $3}' | while read -r lib; do
+        [ -f "$lib" ] || continue
+        copy_file "$lib"
+    done
+done
+
+# ── 4. Kerberos / GSSAPI ─────────────────────────────────────────────────────
+# Knox использует SPNEGO/Kerberos для backend-аутентификации к Hadoop-сервисам.
+echo ">>> kinit binary + dynamic deps"
+KINIT_REAL="$(readlink -f "$(which kinit)")"
+copy_with_deps "$KINIT_REAL"
+
+mkdir -p "${ROOTFS}/bin"
+[ -e "${ROOTFS}/bin/kinit" ] || ln -sf "$KINIT_REAL" "${ROOTFS}/bin/kinit"
+
+echo ">>> Kerberos / GSSAPI libraries"
+for krblib in \
+    /usr/lib64/libgssapi_krb5.so* \
+    /usr/lib64/libkrb5.so* \
+    /usr/lib64/libkrb5support.so* \
+    /usr/lib64/libk5crypto.so* \
+    /usr/lib64/libcom_err.so* \
+    /usr/lib64/libgssapi.so* \
+    /usr/lib/libgssapi_krb5.so* \
+    /usr/lib/libkrb5.so* \
+    /usr/lib/libkrb5support.so* \
+    /usr/lib/libk5crypto.so* \
+    /usr/lib/libcom_err.so* \
+    /lib64/libkrb5.so* \
+    /lib64/libkrb5support.so* \
+    /lib64/libk5crypto.so* \
+    /lib64/libcom_err.so*; do
+    [ -f "$krblib" ] || continue
+    copy_file "$krblib"
+    ldd "$krblib" 2>/dev/null | awk '/=>/ {print $3}' | while read -r lib; do
+        [ -f "$lib" ] || continue
+        copy_file "$lib"
+    done
+done
+
+# Плагины GSSAPI
+for gss_dir in /usr/lib64/gss /usr/lib/gss /usr/lib64/krb5/plugins /usr/lib/krb5/plugins; do
+    [ -d "$gss_dir" ] || continue
+    find "$gss_dir" -name "*.so*" -type f | while read -r sofile; do
+        copy_file "$sofile"
+        ldd "$sofile" 2>/dev/null | awk '/=>/ {print $3}' | while read -r lib; do
+            [ -f "$lib" ] || continue
+            copy_file "$lib"
+        done
+    done
+done
+
+# ── 5. NSS-библиотеки (DNS, passwd, group) ──────────────────────────────────
+echo ">>> NSS libraries"
+for nss_so in /lib64/libnss_*.so* /lib/libnss_*.so* /usr/lib64/libnss_*.so* /usr/lib/libnss_*.so*; do
+    [ -f "$nss_so" ] || continue
+    copy_file "$nss_so"
+    ldd "$nss_so" 2>/dev/null | awk '/=>/ {print $3}' | while read -r lib; do
+        [ -f "$lib" ] || continue
+        copy_file "$lib"
+    done
+done
+
+for resolv_so in /lib64/libresolv.so* /lib/libresolv.so* /usr/lib64/libresolv.so* /usr/lib/libresolv.so*; do
+    [ -f "$resolv_so" ] || continue
+    copy_file "$resolv_so"
+done
+
+# ── 6. Системные конфигурационные файлы ──────────────────────────────────────
+echo ">>> System config"
+mkdir -p "${ROOTFS}/etc/ssl/certs" "${ROOTFS}/tmp"
+chmod 1777 "${ROOTFS}/tmp"
+
+cp /etc/passwd  "${ROOTFS}/etc/"
+cp /etc/group   "${ROOTFS}/etc/"
+cp /etc/shadow  "${ROOTFS}/etc/" 2>/dev/null || true
+
+if [ -f /etc/nsswitch.conf ]; then
+    cp /etc/nsswitch.conf "${ROOTFS}/etc/"
+else
+    printf 'passwd:\tfiles\ngroup:\tfiles\nhosts:\tdns files\n' > "${ROOTFS}/etc/nsswitch.conf"
+fi
+
+touch "${ROOTFS}/etc/resolv.conf"
+touch "${ROOTFS}/etc/hosts"
+
+cp -rL /etc/ssl/certs/. "${ROOTFS}/etc/ssl/certs/" 2>/dev/null || true
+cp /etc/pki/tls/certs/ca-bundle.crt "${ROOTFS}/etc/ssl/certs/" 2>/dev/null || true
+
+# ── 7. Временные зоны ────────────────────────────────────────────────────────
+echo ">>> Timezone data"
+mkdir -p "${ROOTFS}/usr/share"
+cp -r /usr/share/zoneinfo "${ROOTFS}/usr/share/" 2>/dev/null || true
+[ -f /etc/localtime ] && copy_file /etc/localtime
+
+find "${ROOTFS}" -name "*.so*" -type f -exec chmod 755 {} \;
diff --color --color=never -ruN /tmp/empty-knox-base/docker/knox-entrypoint.go component-knox-sdphadoop/docker/knox-entrypoint.go
--- /tmp/empty-knox-base/docker/knox-entrypoint.go	1970-01-01 03:00:00
+++ component-knox-sdphadoop/docker/knox-entrypoint.go	2026-05-15 05:03:11
@@ -0,0 +1,349 @@
+// Knox distroless entrypoint.
+//
+// Заменяет shell-based /opt/knox/bin/gateway.sh: собирает classpath,
+// готовит окружение (Kerberos через Vault Agent — опционально), запускает
+// org.apache.knox.gateway.GatewayServer через exec без промежуточного shell.
+package main
+
+import (
+	"encoding/base64"
+	"fmt"
+	"net"
+	"os"
+	"os/exec"
+	"path/filepath"
+	"strings"
+	"syscall"
+	"time"
+)
+
+const (
+	knoxHome = "/opt/knox"
+	javaHome = "/usr/lib/jvm/jre-1.8.0-openjdk"
+
+	gatewayMainClass = "org.apache.knox.gateway.GatewayServer"
+	knoxCliMainClass = "org.apache.knox.gateway.launcher.Launcher"
+)
+
+// buildClasspath собирает classpath: KNOX_CONF_DIR → /opt/knox/dep/*.jar → /opt/knox/lib/*.jar.
+//
+// Knox раскладывает зависимости в dep/ и собственные JAR-ы в lib/. На некоторых
+// SDP-сборках dep/ может отсутствовать — тогда падает на lib/ целиком.
+func buildClasspath() string {
+	seen := make(map[string]struct{})
+	var entries []string
+
+	add := func(path string) {
+		if _, ok := seen[path]; !ok {
+			seen[path] = struct{}{}
+			entries = append(entries, path)
+		}
+	}
+
+	confDir := os.Getenv("KNOX_CONF_DIR")
+	if confDir == "" {
+		confDir = knoxHome + "/conf"
+	}
+	if info, err := os.Stat(confDir); err == nil && info.IsDir() {
+		add(confDir)
+	}
+
+	for _, glob := range []string{
+		knoxHome + "/dep/*.jar",
+		knoxHome + "/lib/*.jar",
+		knoxHome + "/ext/*.jar",
+	} {
+		jars, _ := filepath.Glob(glob)
+		for _, j := range jars {
+			add(j)
+		}
+	}
+
+	return strings.Join(entries, ":")
+}
+
+func buildJvmArgs(mainClass, classpath string, extraArgs []string) []string {
+	javaBin := javaHome + "/bin/java"
+	args := []string{javaBin}
+
+	for _, envVar := range []string{"KNOX_GATEWAY_OPTS", "JAVA_OPTS"} {
+		if opts := os.Getenv(envVar); opts != "" {
+			args = append(args, strings.Fields(opts)...)
+		}
+	}
+
+	args = append(args,
+		"-Dknox.gateway.home="+knoxHome,
+		"-Dgateway.home="+knoxHome,
+		"-Dlog4j.configuration=file:"+os.Getenv("KNOX_CONF_DIR")+"/gateway-log4j.properties",
+		"-cp", classpath,
+		mainClass,
+	)
+	return append(args, extraArgs...)
+}
+
+func logf(format string, a ...interface{}) {
+	fmt.Printf("[%s] %s\n", time.Now().Format(time.RFC3339), fmt.Sprintf(format, a...))
+}
+
+// waitForFile ждёт появления непустого файла. Используется для секретов от Vault Agent.
+func waitForFile(path string, timeout, interval time.Duration) error {
+	deadline := time.Now().Add(timeout)
+	logf("Waiting for non-empty file %s (timeout: %s, interval: %s)", path, timeout, interval)
+	for {
+		info, err := os.Stat(path)
+		if err == nil && info.Size() > 0 {
+			logf("File %s is ready (%d bytes)", path, info.Size())
+			return nil
+		}
+		if time.Now().After(deadline) {
+			if err != nil {
+				return fmt.Errorf("timed out waiting for file %s: %v", path, err)
+			}
+			return fmt.Errorf("timed out waiting for non-empty file %s", path)
+		}
+		time.Sleep(interval)
+	}
+}
+
+// waitFor опрашивает TCP-адрес addr (host:port).
+func waitFor(addr string, timeout, interval time.Duration) error {
+	deadline := time.Now().Add(timeout)
+	logf("Waiting for %s (timeout: %s)", addr, timeout)
+	for {
+		conn, err := net.DialTimeout("tcp", addr, interval)
+		if err == nil {
+			conn.Close()
+			logf("%s is available", addr)
+			return nil
+		}
+		if time.Now().After(deadline) {
+			return fmt.Errorf("timed out waiting for %s: %v", addr, err)
+		}
+		time.Sleep(interval)
+	}
+}
+
+func parseBoolEnv(key string) (value bool, set bool) {
+	raw, exists := os.LookupEnv(key)
+	if !exists {
+		return false, false
+	}
+	switch strings.ToLower(strings.TrimSpace(raw)) {
+	case "1", "true", "yes", "on":
+		return true, true
+	default:
+		return false, true
+	}
+}
+
+type kerberosConfig struct {
+	vaultB64File string
+	keytabFile   string
+	principal    string
+	waitTimeout  time.Duration
+	waitInterval time.Duration
+}
+
+func loadKerberosConfig() kerberosConfig {
+	cfg := kerberosConfig{
+		vaultB64File: os.Getenv("KERBEROS_VAULT_B64_FILE"),
+		keytabFile:   os.Getenv("KERBEROS_KEYTAB_FILE"),
+		principal:    os.Getenv("KERBEROS_PRINCIPAL"),
+		waitTimeout:  120 * time.Second,
+		waitInterval: 2 * time.Second,
+	}
+	if v := os.Getenv("KERBEROS_WAIT_TIMEOUT"); v != "" {
+		if d, err := time.ParseDuration(v); err == nil {
+			cfg.waitTimeout = d
+		}
+	}
+	if v := os.Getenv("KERBEROS_WAIT_INTERVAL"); v != "" {
+		if d, err := time.ParseDuration(v); err == nil {
+			cfg.waitInterval = d
+		}
+	}
+	return cfg
+}
+
+func decodeKeytab(b64File, keytabFile string) error {
+	raw, err := os.ReadFile(b64File)
+	if err != nil {
+		return fmt.Errorf("read b64 file %s: %w", b64File, err)
+	}
+	decoded, err := base64.StdEncoding.DecodeString(strings.TrimSpace(string(raw)))
+	if err != nil {
+		return fmt.Errorf("base64 decode of %s: %w", b64File, err)
+	}
+	if err := os.MkdirAll(filepath.Dir(keytabFile), 0755); err != nil {
+		return fmt.Errorf("mkdir for keytab %s: %w", keytabFile, err)
+	}
+	if err := os.WriteFile(keytabFile, decoded, 0600); err != nil {
+		return fmt.Errorf("write keytab %s: %w", keytabFile, err)
+	}
+	logf("Keytab written to %s (%d bytes)", keytabFile, len(decoded))
+	return nil
+}
+
+// prepareKerberos декодирует keytab от Vault Agent (если задан) и запускает kinit.
+// Сценарии аналогичны hive-entrypoint.go: secman=true → берём из /vault/secrets,
+// secman=false → keytab уже смонтирован в KERBEROS_KEYTAB_FILE.
+func prepareKerberos(env []string) []string {
+	enabled, set := parseBoolEnv("KERBEROS_ENABLED")
+	if !set || !enabled {
+		logf("KERBEROS_ENABLED not set or false, skipping Kerberos setup")
+		return env
+	}
+
+	cfg := loadKerberosConfig()
+
+	if cfg.vaultB64File != "" {
+		if err := waitForFile(cfg.vaultB64File, cfg.waitTimeout, cfg.waitInterval); err != nil {
+			fmt.Fprintf(os.Stderr, "kerberos: keytab vault file wait failed: %v\n", err)
+			os.Exit(1)
+		}
+		if err := decodeKeytab(cfg.vaultB64File, cfg.keytabFile); err != nil {
+			fmt.Fprintf(os.Stderr, "kerberos: keytab decode failed: %v\n", err)
+			os.Exit(1)
+		}
+	} else {
+		if _, err := os.Stat(cfg.keytabFile); err != nil {
+			fmt.Fprintf(os.Stderr, "kerberos: keytab not found at %s: %v\n", cfg.keytabFile, err)
+			os.Exit(1)
+		}
+		logf("Using pre-mounted keytab at %s", cfg.keytabFile)
+	}
+
+	if cfg.principal == "" {
+		fmt.Fprintf(os.Stderr, "kerberos: KERBEROS_PRINCIPAL is required\n")
+		os.Exit(1)
+	}
+
+	logf("Running kinit for %s", cfg.principal)
+	cmd := exec.Command("kinit", "-kt", cfg.keytabFile, cfg.principal)
+	cmd.Stdout = os.Stdout
+	cmd.Stderr = os.Stderr
+	if err := cmd.Run(); err != nil {
+		fmt.Fprintf(os.Stderr, "kinit failed for %s: %v\n", cfg.principal, err)
+		os.Exit(1)
+	}
+	logf("kinit succeeded for %s", cfg.principal)
+
+	return env
+}
+
+// prepareEnv выставляет дефолты и подмешивает Kerberos-конфигурацию.
+func prepareEnv() []string {
+	env := os.Environ()
+	hasVar := func(key string) bool {
+		prefix := key + "="
+		for _, e := range env {
+			if strings.HasPrefix(e, prefix) {
+				return true
+			}
+		}
+		return false
+	}
+
+	defaults := map[string]string{
+		"KNOX_HOME":     knoxHome,
+		"JAVA_HOME":     javaHome,
+		"KNOX_CONF_DIR": knoxHome + "/conf",
+		"KNOX_DATA_DIR": "/var/lib/knox/data",
+		"KNOX_LOG_DIR":  "/var/log/knox",
+		"KNOX_PID_DIR":  "/var/run/knox",
+	}
+	for k, v := range defaults {
+		if !hasVar(k) {
+			env = append(env, k+"="+v)
+		}
+	}
+	return env
+}
+
+func execJava(mainClass, classpath string, args []string, env []string) {
+	javaBin := javaHome + "/bin/java"
+	jvmArgs := buildJvmArgs(mainClass, classpath, args)
+	if err := syscall.Exec(javaBin, jvmArgs, env); err != nil {
+		fmt.Fprintf(os.Stderr, "exec %s: %v\n", javaBin, err)
+		os.Exit(1)
+	}
+}
+
+func runJava(mainClass, classpath string, args []string, env []string) error {
+	jvmArgs := buildJvmArgs(mainClass, classpath, args)
+	cmd := exec.Command(jvmArgs[0], jvmArgs[1:]...)
+	cmd.Env = env
+	cmd.Stdout = os.Stdout
+	cmd.Stderr = os.Stderr
+	return cmd.Run()
+}
+
+func printUsage() {
+	fmt.Fprintln(os.Stderr, "Usage: knox-entrypoint <command> [args...]")
+	fmt.Fprintln(os.Stderr, "Commands:")
+	fmt.Fprintln(os.Stderr, "  gateway              Start Knox Gateway server (default)")
+	fmt.Fprintln(os.Stderr, "  cli [args...]        Run Knox CLI (org.apache.knox.gateway.launcher.Launcher)")
+	fmt.Fprintln(os.Stderr, "  wait-for <host:port> Wait for TCP endpoint")
+	fmt.Fprintln(os.Stderr, "  idle                 Block forever (debug)")
+}
+
+func main() {
+	if len(os.Args) < 2 {
+		printUsage()
+		os.Exit(1)
+	}
+
+	command := os.Args[1]
+	classpath := buildClasspath()
+	env := prepareEnv()
+
+	if command != "idle" && command != "wait-for" {
+		env = prepareKerberos(env)
+	}
+
+	switch command {
+
+	case "idle":
+		select {}
+
+	case "wait-for":
+		if len(os.Args) < 3 {
+			fmt.Fprintln(os.Stderr, "Usage: knox-entrypoint wait-for <host:port> [--timeout=120s]")
+			os.Exit(1)
+		}
+		addr := os.Args[2]
+		timeout := 120 * time.Second
+		for _, arg := range os.Args[3:] {
+			if strings.HasPrefix(arg, "--timeout=") {
+				val := strings.TrimPrefix(arg, "--timeout=")
+				if d, err := time.ParseDuration(val); err == nil {
+					timeout = d
+				}
+			}
+		}
+		if err := waitFor(addr, timeout, 2*time.Second); err != nil {
+			fmt.Fprintln(os.Stderr, err)
+			os.Exit(1)
+		}
+
+	case "cli":
+		// CLI используется для генерации мастер-ключа, alias-ов, sub-CAs и т.д.
+		args := os.Args[2:]
+		if err := runJava(knoxCliMainClass, classpath, args, env); err != nil {
+			fmt.Fprintf(os.Stderr, "knox cli failed: %v\n", err)
+			os.Exit(1)
+		}
+
+	case "gateway":
+		args := os.Args[2:]
+		logf("Starting Knox Gateway server (data=%s, conf=%s)",
+			os.Getenv("KNOX_DATA_DIR"), os.Getenv("KNOX_CONF_DIR"))
+		execJava(gatewayMainClass, classpath, args, env)
+
+	default:
+		fmt.Fprintf(os.Stderr, "Unknown command: %s\n", command)
+		printUsage()
+		os.Exit(1)
+	}
+}
