+++ component-knox-sdphadoop/Jenkinsfile	2026-05-15 05:04:40
@@ -0,0 +1,78 @@
+@Library("sdp-pipelines@sdp-develop")
+
+import ru.sber.Variables
+
+
+pipeline {
+    agent { node { label "sdpozonebuilder" } }
+    options {
+        ansiColor("xterm")
+        // convention is here: https://sbtatlas.sigma.sbrf.ru/wiki/pages/viewpage.action?pageId=75932050
+        buildDiscarder logRotator(
+                artifactDaysToKeepStr: "7",
+                artifactNumToKeepStr: "10",
+                daysToKeepStr: "7",
+                numToKeepStr: "50"
+        )
+        durabilityHint "PERFORMANCE_OPTIMIZED"
+        skipStagesAfterUnstable()
+    }
+    parameters {
+        string(
+                name: 'KNOX_VERSION_TAG',
+                defaultValue: '1.6.1',
+                description: 'Tag for docker image (Apache Knox upstream version)'
+        )
+        string(
+                name: 'KNOX_RPM_URL',
+                defaultValue: 'https://tslew-psdp00001.esrt.sber.ru/sdp/3.5.7.0/sdp-3.5.7.0/knox/knox_3_5_7_0_1-1.6.1.3.5.7.0-XXX.noarch.rpm',
+                description: 'URL Knox RPM из корпоративного зеркала SDP'
+        )
+        booleanParam(
+            name: "UPDATE_PARAMS",
+            defaultValue: false,
+            description: "Dry run, no changes, like 2 at https://dev.to/pencillr/jenkins-pipelines-and-their-dirty-secrets-2"
+        )
+    }
+    stages {
+        stage("Update params") {
+            when {
+                anyOf {
+                    equals expected: true, actual: params.updateParams
+                    equals expected: 1, actual: currentBuild.number
+                }
+            }
+            steps {
+                script {
+                    sdpStageUpdateParams()
+                }
+            }
+        }
+        stage("Build & push docker image") {
+            when { equals expected: false, actual: Variables.updateParams }
+            steps {
+                script {
+                    sh script: """
+                        docker build \
+                            --build-arg KNOX_RPM_URL=${params.KNOX_RPM_URL} \
+                            -t docker-dev.registry-ci.delta.sbrf.ru/ci04674694/ci04674694/knox:${params.KNOX_VERSION_TAG} \
+                            -f component-knox-sdphadoop/docker/Dockerfile component-knox-sdphadoop/
+                    """
+                }
+            }
+        }
+        stage("Push docker image") {
+            when { equals expected: false, actual: Variables.updateParams }
+            steps {
+                script {
+                    sh script: """
+                        docker tag docker-dev.registry-ci.delta.sbrf.ru/ci04674694/ci04674694/knox:${params.KNOX_VERSION_TAG} docker-dev.registry-ci.delta.sbrf.ru/ci04674694/ci04674694/knox:latest
+
+                        docker push docker-dev.registry-ci.delta.sbrf.ru/ci04674694/ci04674694/knox:${params.KNOX_VERSION_TAG}
+                        docker push docker-dev.registry-ci.delta.sbrf.ru/ci04674694/ci04674694/knox:latest
+                    """
+                }
+            }
+        }
+    }
+}
