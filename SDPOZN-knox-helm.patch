       # Таймауты ожидания Vault-файла с keytab
@@ -264,6 +265,91 @@ recon:
     host: ""
     tls: []
 
+# Apache Knox Gateway — единая точка входа для UI/REST сервисов Ozone.
+# Знает топологию sdpozone (см. templates/knox/configmap.yaml), которая
+# проксирует /gateway/sdpozone/recon/ → Ozone Recon и опционально S3G.
+knox:
+  enabled: false
+  replicas: 1
+  component: knox
+  serviceName: knox
+  image:
+    # Override per-environment; falls back to global.image.registry if empty
+    registry: ""
+    repository: knox
+    tag: "1.6.1"
+  resources:
+    requests:
+      memory: "1Gi"
+      cpu: "300m"
+    limits:
+      memory: "1Gi"
+      cpu: "1"
+  service:
+    port: 8443
+  # Knox image создаётся с user `knox` UID 10001 (см. component-knox/docker/Dockerfile).
+  # /home/knox принадлежит knox:knox, поэтому глобальные runAsUser/runAsGroup=1000
+  # не могут даже выполнить stat → "permission denied" в init контейнера.
+  # Переопределяем под образ.
+  securityContext:
+    allowPrivilegeEscalation: false
+    runAsNonRoot: true
+    runAsUser: 10001
+    runAsGroup: 10001
+    seccompProfile:
+      type: RuntimeDefault
+    capabilities:
+      drop:
+      - ALL
+  podSecurityContext:
+    fsGroup: 10001
+  auth:
+    # anonymous | sso | basic | kerberos
+    #   anonymous — нет проверки, все запросы пропускаются (для smoke-test)
+    #   sso       — KnoxSSO + login form + JWT cookie hadoop-jwt
+    #               (две topology: sdpozone с SSOCookieProvider + knoxsso с IniRealm)
+    #   basic     — HTTP Basic через Shiro (на каждый запрос)
+    #   kerberos  — SPNEGO (требует Kerberos enabled)
+    mode: anonymous
+    # Настройки SSO режима. Используются только при auth.mode=sso.
+    sso:
+      # Inline Shiro IniRealm пользователи. Формат [users].
+      # В configmap это попадает как plain text, доступ — Kubernetes RBAC namespace.
+      # Для prod-grade — переносить в Vault через secman (см. README).
+      users:
+        - username: admin
+          # ВНИМАНИЕ: для DEV. Для prod использовать sha256-hash или Vault.
+          password: admin-password
+          roles: admin
+      # Время жизни JWT-cookie hadoop-jwt в миллисекундах (default 1h).
+      cookieTtl: 3600000
+      # Whitelist regex для post-login redirect. Knox проверяет originalUrl
+      # против этого паттерна, иначе 400. Если пусто — автогенерится из
+      # recon.ingress.host (только текущий хост приложения).
+      whitelistRegex: ""
+  # Master secret для Knox alias-keystore. Берётся только из Vault через
+  # Secman; ключ задаётся в knox.secman.masterSecretKey.
+  secman:
+    masterSecretKey: ""
+  # Включает full protection: nginx-ingress делает auth-url subrequest
+  # к Knox WebSSO на каждом запросе к Recon. Если нет валидного cookie
+  # hadoop-jwt → редирект на login form.
+  #
+  # ТРЕБУЕТ: enable-snippet-annotations=true в global config nginx-ingress
+  # (нужен cluster admin). Без этого ingress отвергнет конфигурацию
+  # или вернёт 500 из-за TLS verify к self-signed Knox cert.
+  #
+  # Если выключено — Recon открыт напрямую, login/logout доступны вручную
+  # через /gateway/sdpozone/.
+  protection:
+    enabled: false
+  ingress:
+    enabled: false
+    className: nginx
+    host: ""
+    tls: []
+    annotations: {}
+
 # S3 Gateway configuration
 s3g:
   enabled: true
