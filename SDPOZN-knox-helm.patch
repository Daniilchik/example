+{{- end }}
diff --git a/helm-charts/ozone/templates/knox/services-configmap.yaml b/helm-charts/ozone/templates/knox/services-configmap.yaml
new file mode 100644
index 0000000..4ae7bd0
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/services-configmap.yaml
@@ -0,0 +1,122 @@
+{{- if .Values.knox.enabled }}
+{{/*
+  Custom Knox service definitions for Ozone services.
+
+  Apache Knox в стандартном image знает только Hadoop-сервисы (NAMENODE,
+  RESOURCEMANAGER, WEBHDFS, HIVE, RANGER, ...). Для Ozone-specific сервисов
+  (Recon, S3G UI, OM UI) нужны custom service.xml + rewrite.xml.
+
+  Этот ConfigMap содержит определение RECON service, которое монтируется в
+  pod-е Knox в путь /home/knox/conf/services/recon/1.0.0/. При старте Knox
+  читает gateway.services.dir и подхватывает наше определение.
+
+  Архитектурно правильнее запекать эти XML в Knox image (apache-builders),
+  но для гибкости делаем через ConfigMap — можно править без rebuild.
+*/}}
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: {{ include "ozone.fullname" . }}-knox-services-recon
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+data:
+  service.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <!-- Knox service definition for Apache Ozone Recon UI.
+
+         role="RECON" — используется в topology <service><role>RECON</role>
+         name="recon" — URL segment: /gateway/<topology>/recon/
+         version="1.0.0" — должна совпадать с именем родительской папки
+         dispatch — DefaultDispatch достаточно для passthrough HTTP-сервиса
+    -->
+    <service role="RECON" name="recon" version="1.0.0">
+        <metadata>
+            <type>UI</type>
+            <context>/recon</context>
+            <shortDesc>Apache Ozone Recon</shortDesc>
+        </metadata>
+        <routes>
+            <route path="/recon"/>
+            <route path="/recon/"/>
+            <route path="/recon/**"/>
+            <route path="/recon/**?**"/>
+        </routes>
+        <dispatch classname="org.apache.knox.gateway.dispatch.DefaultDispatch"/>
+    </service>
+
+  rewrite.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <!-- URL rewrite rules для RECON service.
+
+         IN-правила (входящий запрос от клиента):
+           /gateway/sdpozone/recon/foo?bar  →  http://recon:9888/foo?bar
+
+         OUT-правила (response от Recon к клиенту):
+           Переписываем абсолютные пути в HTML, чтобы SPA подгрузил assets:
+             "/static/..."  →  "/gateway/sdpozone/recon/static/..."
+             "/api/..."     →  "/gateway/sdpozone/recon/api/..."
+
+           ВАЖНО: захардкодили "/gateway/sdpozone/recon/", НЕ используем
+           {topology}/{gateway.path} переменные — в outbound контексте
+           они часто не resolved → подставляются как "null" →
+           NumberFormatException где-то в Knox dispatch.
+
+           OUT-правила работают через filter, применяемый на HTML body.
+           Не сработает если Recon — React SPA с путями в JS-bundle
+           (тогда нужен JS-rewrite, что слишком сложно — ищи другой путь).
+    -->
+    <rules>
+        <!-- INBOUND -->
+        <rule dir="IN" name="RECON/recon/inbound/root"
+              pattern="*://*:*/**/recon/?{**}">
+            <rewrite template="{$serviceUrl[RECON]}/?{**}"/>
+        </rule>
+        <rule dir="IN" name="RECON/recon/inbound/path"
+              pattern="*://*:*/**/recon/{path=**}?{**}">
+            <rewrite template="{$serviceUrl[RECON]}/{path=**}?{**}"/>
+        </rule>
+
+        <!-- OUTBOUND правила для absolute paths в HTML.
+             Recon UI это React SPA — HTML содержит:
+               <link href="/static/css/main.xxx.chunk.css">
+               <link href="/manifest.json">
+               <link rel="shortcut icon" href="/favicon.ico">
+               <script src="/static/js/main.xxx.chunk.js">
+             Все надо переписать в /gateway/sdpozone/recon/... -->
+        <rule dir="OUT" flow="OR" name="RECON/recon/outbound/static"
+              pattern="/static/{**}">
+            <rewrite template="/gateway/sdpozone/recon/static/{**}"/>
+        </rule>
+        <rule dir="OUT" flow="OR" name="RECON/recon/outbound/api"
+              pattern="/api/{**}">
+            <rewrite template="/gateway/sdpozone/recon/api/{**}"/>
+        </rule>
+        <rule dir="OUT" flow="OR" name="RECON/recon/outbound/v1"
+              pattern="/v1/{**}">
+            <rewrite template="/gateway/sdpozone/recon/v1/{**}"/>
+        </rule>
+        <rule dir="OUT" flow="OR" name="RECON/recon/outbound/manifest"
+              pattern="/manifest.json">
+            <rewrite template="/gateway/sdpozone/recon/manifest.json"/>
+        </rule>
+        <rule dir="OUT" flow="OR" name="RECON/recon/outbound/favicon"
+              pattern="/favicon.ico">
+            <rewrite template="/gateway/sdpozone/recon/favicon.ico"/>
+        </rule>
+
+        <!-- Filter применяет правила к HTML response.
+             content type "*/html" покрывает text/html, application/html и т.д. -->
+        <filter name="RECON/recon/outbound/html-filter">
+            <content type="*/html">
+                <apply path="//link/@href" rule="RECON/recon/outbound/static"/>
+                <apply path="//link/@href" rule="RECON/recon/outbound/manifest"/>
+                <apply path="//link/@href" rule="RECON/recon/outbound/favicon"/>
+                <apply path="//script/@src" rule="RECON/recon/outbound/static"/>
+                <apply path="//img/@src" rule="RECON/recon/outbound/static"/>
+                <apply path="//a/@href" rule="RECON/recon/outbound/static"/>
+            </content>
+        </filter>
+    </rules>
+{{- end }}
diff --git a/helm-charts/ozone/values.yaml b/helm-charts/ozone/values.yaml
index 3d6a249..755b764 100644
--- a/helm-charts/ozone/values.yaml
+++ b/helm-charts/ozone/values.yaml
@@ -77,6 +77,7 @@ global:
         s3g: "s3g_keytab_b64"
         recon: "recon_keytab_b64"
         hms: "hms_keytab_b64"
+        knox: "knox_keytab_b64"
       # Директория в контейнере, куда пишется декодированный keytab
       keytabDir: "/etc/security/keytabs"
       # Таймауты ожидания Vault-файла с keytab
@@ -264,6 +265,70 @@ recon:
     host: ""
     tls: []
 
+# Apache Knox Gateway — единая точка входа для UI/REST сервисов Ozone.
+# Знает топологию sdpozone (см. templates/knox/configmap.yaml), которая
+# проксирует /gateway/sdpozone/recon/ → Ozone Recon и опционально S3G.
+knox:
+  enabled: false
+  replicas: 1
+  component: knox
+  serviceName: knox
+  image:
+    # Override per-environment; falls back to global.image.registry if empty
+    registry: ""
+    repository: knox
+    tag: "1.6.1"
+  resources:
+    requests:
+      memory: "1Gi"
+      cpu: "300m"
+    limits:
+      memory: "1Gi"
+      cpu: "1"
+  service:
+    port: 8443
+  # Knox image создаётся с user `knox` UID 10001 (см. component-knox/docker/Dockerfile).
+  # /home/knox принадлежит knox:knox, поэтому глобальные runAsUser/runAsGroup=1000
+  # не могут даже выполнить stat → "permission denied" в init контейнера.
+  # Переопределяем под образ.
+  securityContext:
+    allowPrivilegeEscalation: false
+    runAsNonRoot: true
+    runAsUser: 10001
+    runAsGroup: 10001
+    seccompProfile:
+      type: RuntimeDefault
+    capabilities:
+      drop:
+      - ALL
+  podSecurityContext:
+    fsGroup: 10001
+  auth:
+    # anonymous | basic | kerberos
+    # anonymous — для DEV (без проверки), basic — Shiro c LDAP/файлом, kerberos — SPNEGO
+    mode: anonymous
+  # Master secret для Knox alias-keystore (gateway-identity-passphrase и пр.).
+  # Knox при первом старте читает его с TTY через System.console(); в pod-е TTY
+  # нет → "No console" и крах. Делаем initContainer, который запускает
+  # `bin/knoxcli.sh create-master --master <secret>` ДО запуска gateway.sh.
+  #
+  # При secman.enabled=true секрет берётся из Vault по ключу masterSecretKey
+  # (Vault Agent кладёт его в /vault/secrets/knox-master-secret).
+  # Иначе — из этого литерала (только для DEV; в PROD не использовать).
+  masterSecret: ""
+  secman:
+    masterSecretKey: ""
+  proxy:
+    s3g:
+      # Включает проксирование S3 Gateway через Knox в дополнение к Recon
+      enabled: false
+  ingress:
+    enabled: false
+    className: nginx
+    host: ""
+    tls: []
+    annotations: {}
+
 # S3 Gateway configuration
 s3g:
   enabled: true
