+        password: admin-password
+        roles: admin
+    # JWT cookie TTL in millis.
+    cookieTtl: 3600000
+    # KnoxSSO post-login redirect whitelist regex. Empty = auto-generate from recon.ingress.host.
+    whitelistRegex: ""
