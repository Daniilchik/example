diff --git a/helm-charts/ozone/templates/ingress.yaml b/helm-charts/ozone/templates/ingress.yaml
index 8c36624..6669093 100644
--- a/helm-charts/ozone/templates/ingress.yaml
+++ b/helm-charts/ozone/templates/ingress.yaml
@@ -1,5 +1,76 @@
 {{- if and .Values.recon.enabled .Values.recon.ingress.enabled }}
+{{- $reconHost := include "ozone.ingress.host" (dict "host" .Values.recon.ingress.host "component" .Values.recon.serviceName "ctx" .) }}
+
+{{- if .Values.knox.enabled }}
 ---
+# Redirect empty path /ozone-recon[/] -> /index.html (Knox 2.x route pattern requires non-empty suffix).
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ .Values.recon.serviceName }}-knox-recon-redirect-slash
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+  annotations:
+    nginx.ingress.kubernetes.io/permanent-redirect: "/gateway/sdpozone/ozone-recon/index.html"
+    nginx.ingress.kubernetes.io/permanent-redirect-code: "302"
+spec:
+  ingressClassName: {{ .Values.recon.ingress.className }}
+  rules:
+    - host: {{ $reconHost }}
+      http:
+        paths:
+          - path: /gateway/sdpozone/ozone-recon/
+            pathType: Exact
+            backend:
+              service:
+                name: {{ .Values.knox.serviceName }}
+                port:
+                  number: {{ .Values.knox.service.port }}
+          - path: /gateway/sdpozone/ozone-recon
+            pathType: Exact
+            backend:
+              service:
+                name: {{ .Values.knox.serviceName }}
+                port:
+                  number: {{ .Values.knox.service.port }}
+---
+# /gateway/* -> Knox (login form + WebSSO). No auth-url here to avoid login redirect loop.
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ .Values.recon.serviceName }}-knox-gateway
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-recon-knox-gateway
+  annotations:
+    # Knox gateway listens on HTTPS 8443 with self-signed cert.
+    nginx.ingress.kubernetes.io/backend-protocol: "HTTPS"
+    {{- with .Values.recon.ingress.annotations }}
+    {{- toYaml . | nindent 4 }}
+    {{- end }}
+spec:
+  ingressClassName: {{ .Values.recon.ingress.className }}
+  rules:
+    - host: {{ $reconHost }}
+      http:
+        paths:
+          - path: /gateway
+            pathType: Prefix
+            backend:
+              service:
+                name: {{ .Values.knox.serviceName }}
+                port:
+                  number: {{ .Values.knox.service.port }}
+  {{- if .Values.recon.ingress.tls }}
+  tls:
+    {{- toYaml .Values.recon.ingress.tls | nindent 4 }}
+  {{- end }}
+{{- end }}
+
+---
+# Recon root ingress. With knox.protection.enabled: nginx auth-url subrequest enforces JWT.
 apiVersion: networking.k8s.io/v1
 kind: Ingress
 metadata:
@@ -8,14 +79,21 @@ metadata:
   labels:
     {{- include "ozone.labels" . | nindent 4 }}
     app.kubernetes.io/component: ozone-recon
-  {{- with .Values.recon.ingress.annotations }}
   annotations:
+    {{- with .Values.recon.ingress.annotations }}
     {{- toYaml . | nindent 4 }}
-  {{- end }}
+    {{- end }}
+    {{- if and .Values.knox.enabled .Values.knox.protection.enabled }}
+    # Full JWT enforcement via auth-url subrequest. Requires nginx-ingress snippet annotations.
+    nginx.ingress.kubernetes.io/auth-url: "https://{{ .Values.knox.serviceName }}.{{ include "ozone.namespace" . }}.svc.{{ .Values.global.clusterDomain }}:{{ .Values.knox.service.port }}/gateway/knoxsso/api/v1/websso"
+    nginx.ingress.kubernetes.io/auth-signin: "https://$host/gateway/knoxsso/knoxauth/login.html?originalUrl=https://$host$escaped_request_uri"
+    nginx.ingress.kubernetes.io/auth-snippet: |
+      proxy_ssl_verify off;
+    {{- end }}
 spec:
   ingressClassName: {{ .Values.recon.ingress.className }}
   rules:
-    - host: {{ include "ozone.ingress.host" (dict "host" .Values.recon.ingress.host "component" .Values.recon.serviceName "ctx" .) }}
+    - host: {{ $reconHost }}
       http:
         paths:
           - path: /
diff --git a/helm-charts/ozone/templates/istio/authorizationpolicy.yaml b/helm-charts/ozone/templates/istio/authorizationpolicy.yaml
index af61460..a044b0b 100644
--- a/helm-charts/ozone/templates/istio/authorizationpolicy.yaml
+++ b/helm-charts/ozone/templates/istio/authorizationpolicy.yaml
