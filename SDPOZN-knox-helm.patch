diff --git a/helm-charts/ozone/templates/knox/services-configmap.yaml b/helm-charts/ozone/templates/knox/services-configmap.yaml
new file mode 100644
index 0000000..0375c68
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/services-configmap.yaml
@@ -0,0 +1,48 @@
+{{- if .Values.knox.enabled }}
+{{/*
+  Override Apache OZONE-RECON service.xml.
+
+  В встроенном image service.xml нет <dispatch> блока → Knox использует
+  default DefaultDispatch, который через Apache HttpClient
+  SSLConnectionSocketFactory делает HTTPS handshake к backend независимо
+  от URL scheme → SSLException Connection reset к http://recon:9888.
+
+  <dispatch> в topology НЕ перекрывает service.xml dispatch для встроенных
+  Apache definitions. Поэтому мы кладём собственный service.xml поверх
+  файла из image через subPath mount.
+
+  Файл: /home/knox/data/services/ozone-recon/1.2.0/service.xml (override).
+  rewrite.xml из image остаётся нетронутым.
+*/}}
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: {{ include "ozone.fullname" . }}-knox-services-recon-override
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+data:
+  service.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <service role="OZONE-RECON" name="ozone-recon" version="1.2.0">
+        <metadata>
+            <type>UI</type>
+            <context>/ozone-recon/index.html</context>
+            <shortDesc>OZONE Recon UI</shortDesc>
+        </metadata>
+        <routes>
+            <route path="/ozone-recon"/>
+            <route path="/ozone-recon/**"/>
+            <route path="/ozone-recon/static/js/**">
+                <rewrite apply="OZONE-RECON/filter/staticLinks" to="response.body"/>
+            </route>
+        </routes>
+        <!-- PassAllHeadersNoEncodingDispatch — extends DefaultDispatch,
+             implements Dispatch (без cast errors). Передаёт все headers
+             как есть.
+             UrlConnectionDispatch не подошёл — он не имплементирует Dispatch
+             interface в Knox 1.6.x (legacy adapter для другого механизма). -->
+        <dispatch classname="org.apache.knox.gateway.dispatch.PassAllHeadersNoEncodingDispatch"/>
+    </service>
+{{- end }}
diff --git a/helm-charts/ozone/values.yaml b/helm-charts/ozone/values.yaml
index 3d6a249..65b808e 100644
--- a/helm-charts/ozone/values.yaml
+++ b/helm-charts/ozone/values.yaml
@@ -77,6 +77,7 @@ global:
         s3g: "s3g_keytab_b64"
         recon: "recon_keytab_b64"
         hms: "hms_keytab_b64"
+        knox: "knox_keytab_b64"
       # Директория в контейнере, куда пишется декодированный keytab
       keytabDir: "/etc/security/keytabs"
       # Таймауты ожидания Vault-файла с keytab
@@ -264,6 +265,71 @@ recon:
     host: ""
     tls: []
 
+# Apache Knox Gateway — единая точка входа для UI/REST сервисов Ozone.
+# Знает топологию sdpozone (см. templates/knox/configmap.yaml), которая
+# проксирует /gateway/sdpozone/recon/ → Ozone Recon и опционально S3G.
+knox:
+  enabled: false
+  replicas: 1
+  component: knox
+  serviceName: knox
+  image:
+    # Override per-environment; falls back to global.image.registry if empty
+    registry: ""
+    repository: knox
+    tag: "1.6.1"
+  resources:
+    requests:
+      memory: "1Gi"
+      cpu: "300m"
+    limits:
+      memory: "1Gi"
+      cpu: "1"
+  service:
+    port: 8443
+  # Knox image создаётся с user `knox` UID 10001 (см. component-knox/docker/Dockerfile).
+  # /home/knox принадлежит knox:knox, поэтому глобальные runAsUser/runAsGroup=1000
+  # не могут даже выполнить stat → "permission denied" в init контейнера.
+  # Переопределяем под образ.
+  securityContext:
+    allowPrivilegeEscalation: false
+    runAsNonRoot: true
+    runAsUser: 10001
+    runAsGroup: 10001
+    seccompProfile:
+      type: RuntimeDefault
+    capabilities:
+      drop:
+      - ALL
+  podSecurityContext:
+    fsGroup: 10001
+  auth:
+    # anonymous | basic | kerberos
+    # anonymous — для DEV (без проверки), basic — Shiro c LDAP/файлом, kerberos — SPNEGO
+    mode: anonymous
+  # Master secret для Knox alias-keystore. Берётся только из Vault через
+  # Secman; ключ задаётся в knox.secman.masterSecretKey.
+  secman:
+    masterSecretKey: ""
+  # Включает full protection: nginx-ingress делает auth-url subrequest
+  # к Knox WebSSO на каждом запросе к Recon. Если нет валидного cookie
+  # hadoop-jwt → редирект на login form.
+  #
+  # ТРЕБУЕТ: enable-snippet-annotations=true в global config nginx-ingress
+  # (нужен cluster admin). Без этого ingress отвергнет конфигурацию
+  # или вернёт 500 из-за TLS verify к self-signed Knox cert.
+  #
+  # Если выключено — Recon открыт напрямую, login/logout доступны вручную
+  # через /gateway/sdpozone/.
+  protection:
+    enabled: false
+  ingress:
+    enabled: false
+    className: nginx
+    host: ""
+    tls: []
+    annotations: {}
+
 # S3 Gateway configuration
 s3g:
   enabled: true
