+# Apache Knox Gateway — entrypoint for Recon UI with login form + JWT.
+knox:
+  enabled: false
+  replicas: 1
+  component: knox
+  serviceName: knox
+  image:
+    # Override per-environment; falls back to global.image.registry if empty
+    registry: ""
+    repository: knox
+    tag: "1.6.1"
+  resources:
+    requests:
+      memory: "1Gi"
+      cpu: "300m"
+    limits:
+      memory: "1Gi"
+      cpu: "1"
+  service:
+    port: 8443
+  # Knox image runs as UID 10001 (knox user), overrides global runAsUser=1000.
+  securityContext:
+    allowPrivilegeEscalation: false
+    runAsNonRoot: true
+    runAsUser: 10001
+    runAsGroup: 10001
+    seccompProfile:
