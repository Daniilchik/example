diff --git a/helm-charts/ozone/templates/ingress.yaml b/helm-charts/ozone/templates/ingress.yaml
index 8c36624..c8f55ec 100644
--- a/helm-charts/ozone/templates/ingress.yaml
+++ b/helm-charts/ozone/templates/ingress.yaml
@@ -1,5 +1,48 @@
 {{- if and .Values.recon.enabled .Values.recon.ingress.enabled }}
+{{- $reconHost := include "ozone.ingress.host" (dict "host" .Values.recon.ingress.host "component" .Values.recon.serviceName "ctx" .) }}
+
+{{- if .Values.knox.enabled }}
+---
+# Ingress #1 — /gateway/* идёт на Knox БЕЗ auth-url.
+# Если бы auth-url был и на этом пути — была бы бесконечная рекурсия
+# (login страница защищена auth, который сам ведёт на login).
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ .Values.recon.serviceName }}-knox-gateway
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-recon-knox-gateway
+  annotations:
+    # Knox принимает HTTPS на 8443.
+    nginx.ingress.kubernetes.io/backend-protocol: "HTTPS"
+    {{- with .Values.recon.ingress.annotations }}
+    {{- toYaml . | nindent 4 }}
+    {{- end }}
+spec:
+  ingressClassName: {{ .Values.recon.ingress.className }}
+  rules:
+    - host: {{ $reconHost }}
+      http:
+        paths:
+          - path: /gateway
+            pathType: Prefix
+            backend:
+              service:
+                name: {{ .Values.knox.serviceName }}
+                port:
+                  number: {{ .Values.knox.service.port }}
+  {{- if .Values.recon.ingress.tls }}
+  tls:
+    {{- toYaml .Values.recon.ingress.tls | nindent 4 }}
+  {{- end }}
+{{- end }}
+
 ---
+# Ingress #2 — корневой Recon с auth-url subrequest на Knox.
+# Любой запрос к Recon проверяется через Knox WebSSO. Если cookie
+# hadoop-jwt отсутствует или невалиден — редирект на login page.
 apiVersion: networking.k8s.io/v1
 kind: Ingress
 metadata:
@@ -8,14 +51,25 @@ metadata:
   labels:
     {{- include "ozone.labels" . | nindent 4 }}
     app.kubernetes.io/component: ozone-recon
-  {{- with .Values.recon.ingress.annotations }}
   annotations:
+    {{- with .Values.recon.ingress.annotations }}
     {{- toYaml . | nindent 4 }}
-  {{- end }}
+    {{- end }}
+    {{- if .Values.knox.enabled }}
+    # auth-url — server-side subrequest от nginx к Knox.
+    # Knox endpoint /api/v1/websso возвращает 200 если есть валидный
+    # hadoop-jwt cookie, иначе 302 или 401 → nginx редиректит на login.
+    nginx.ingress.kubernetes.io/auth-url: "https://{{ .Values.knox.serviceName }}.{{ include "ozone.namespace" . }}.svc.{{ .Values.global.clusterDomain }}:{{ .Values.knox.service.port }}/gateway/sdpozone/api/v1/websso"
+    nginx.ingress.kubernetes.io/auth-signin: "https://$host/gateway/sdpozone/knoxauth/login.html?originalUrl=https://$host$escaped_request_uri"
+    # Передаём cookie от browser-а через subrequest в Knox.
+    nginx.ingress.kubernetes.io/auth-snippet: |
+      proxy_set_header X-Original-URI $request_uri;
+      proxy_set_header Cookie $http_cookie;
+    {{- end }}
 spec:
   ingressClassName: {{ .Values.recon.ingress.className }}
   rules:
-    - host: {{ include "ozone.ingress.host" (dict "host" .Values.recon.ingress.host "component" .Values.recon.serviceName "ctx" .) }}
+    - host: {{ $reconHost }}
       http:
         paths:
           - path: /
diff --git a/helm-charts/ozone/templates/istio/authorizationpolicy.yaml b/helm-charts/ozone/templates/istio/authorizationpolicy.yaml
index af61460..19795a3 100644
--- a/helm-charts/ozone/templates/istio/authorizationpolicy.yaml
+++ b/helm-charts/ozone/templates/istio/authorizationpolicy.yaml
@@ -130,4 +130,34 @@ spec:
     {{- end }}
 {{- end }}
 
+{{/* ── Knox ────────────────────────────────────────────────────────────── */}}
+{{- if .Values.knox.enabled }}
+---
+apiVersion: security.istio.io/v1beta1
+kind: AuthorizationPolicy
+metadata:
+  name: {{ include "ozone.fullname" . }}-knox
+  namespace: {{ $ns }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+spec:
+  selector:
+    matchLabels:
+      component: {{ .Values.knox.component }}
+  action: ALLOW
+  rules:
+    - from:
+        - source:
+            principals:
+              - "cluster.local/ns/{{ $ns }}/sa/default"
+              {{- if and .Values.istio.ingressController.serviceAccount.name .Values.istio.ingressController.serviceAccount.namespace }}
+              - "cluster.local/ns/{{ .Values.istio.ingressController.serviceAccount.namespace }}/sa/{{ .Values.istio.ingressController.serviceAccount.name }}"
+              {{- end }}
+    {{- if not (and .Values.istio.ingressController.serviceAccount.name .Values.istio.ingressController.serviceAccount.namespace) }}
+    - to:
+        - operation:
+            ports: ["{{ .Values.knox.service.port }}"]
+    {{- end }}
+{{- end }}
+
 {{- end }}
diff --git a/helm-charts/ozone/templates/istio/sidecar.yaml b/helm-charts/ozone/templates/istio/sidecar.yaml
index 12e4671..1c5dc85 100644
--- a/helm-charts/ozone/templates/istio/sidecar.yaml
+++ b/helm-charts/ozone/templates/istio/sidecar.yaml
@@ -310,4 +310,38 @@ spec:
         {{- end }}
 {{- end }}
 
+{{- if .Values.knox.enabled }}
+---
+apiVersion: networking.istio.io/v1beta1
+kind: Sidecar
+metadata:
+  name: {{ include "ozone.fullname" . }}-knox
+  namespace: {{ $ns }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+spec:
+  workloadSelector:
+    labels:
+      component: {{ .Values.knox.component }}
+  egress:
+    - hosts:
+        # Knox проксирует Recon (DoD point 5)
+        {{- if .Values.recon.enabled }}
+        - "./{{ .Values.recon.serviceName }}.{{ $ns }}.svc.{{ $dom }}"
+        {{- end }}
+        # Опционально — S3G через Knox
+        {{- if and .Values.s3g.enabled .Values.knox.proxy.s3g.enabled }}
+        - "./{{ .Values.s3g.serviceName }}-rest.{{ $ns }}.svc.{{ $dom }}"
+        {{- end }}
+        {{- if .Values.secman.enabled }}
+        - "./{{ .Values.secman.hostname }}"
+        {{- end }}
+        {{- if .Values.global.security.kerberos.enabled }}
+        - "./{{ required "global.security.kerberos.kdc.hostname is required when kerberos is enabled" .Values.global.security.kerberos.kdc.hostname }}"
+        {{- end }}
+        {{- if and .Values.fluentBit.enabled .Values.fluentBit.restlogsHost }}
+        - "./{{ .Values.fluentBit.restlogsHost }}"
+        {{- end }}
+{{- end }}
+
 {{- end }}
diff --git a/helm-charts/ozone/templates/knox/configmap.yaml b/helm-charts/ozone/templates/knox/configmap.yaml
new file mode 100644
index 0000000..3265ddc
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/configmap.yaml
@@ -0,0 +1,184 @@
+{{- if .Values.knox.enabled }}
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: {{ include "ozone.fullname" . }}-knox-config
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+data:
+  gateway-site.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <configuration>
+      <property>
+        <name>gateway.port</name>
+        <value>{{ .Values.knox.service.port }}</value>
+      </property>
+      <property>
+        <name>gateway.path</name>
+        <value>gateway</value>
+      </property>
+      <property>
+        <name>gateway.gateway.conf.dir</name>
+        <value>/home/knox/conf</value>
+      </property>
+      <property>
+        <name>gateway.data.dir</name>
+        <value>/home/knox/data</value>
+      </property>
+      <property>
+        <name>gateway.deployment.dir</name>
+        <value>/home/knox/data/deployments</value>
+      </property>
+      <property>
+        <name>gateway.security.dir</name>
+        <value>/home/knox/data/security</value>
+      </property>
+      <property>
+        <name>gateway.topology.dir</name>
+        <value>/home/knox/conf/topologies</value>
+      </property>
+      <property>
+        <name>gateway.services.dir</name>
+        <value>/home/knox/conf/services</value>
+      </property>
+      <property>
+        <name>gateway.hadoop.kerberos.secured</name>
+        <value>{{ .Values.global.security.kerberos.enabled }}</value>
+      </property>
+      <property>
+        <name>gateway.tls.keystore.password.alias</name>
+        <value>gateway-identity-passphrase</value>
+      </property>
+    </configuration>
+
+  # SDP Ozone topology — единая точка входа.
+  # URL после деплоя: https://<knox-host>:{{ .Values.knox.service.port }}/gateway/sdpozone/recon/
+  sdpozone.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <!-- Knox topology с KNOXSSO для auth-flow Recon UI.
+         Поток:
+           1. Browser идёт на /recon → ingress делает auth-url subrequest
+              на /gateway/sdpozone/api/v1/websso/verify
+           2. Если нет cookie hadoop-jwt → 401 → ingress редиректит на
+              /gateway/sdpozone/knoxsso/api/v1/websso?originalUrl=/recon
+           3. KNOXSSO показывает login form (Shiro с in-memory users)
+           4. После успешного login Knox выставляет cookie hadoop-jwt
+              на parent domain → редирект обратно на /recon
+           5. Ingress видит cookie → пропускает на Recon
+           6. Logout: GET /gateway/sdpozone/knoxsso/api/v1/websso?logout=true
+              → инвалидирует cookie → следующий запрос на /recon → 401 → login -->
+      <gateway>
+        <provider>
+          <role>authentication</role>
+          <name>ShiroProvider</name>
+          <enabled>true</enabled>
+          <param>
+            <name>sessionTimeout</name>
+            <value>30</value>
+          </param>
+          <!-- In-memory users (только для DEV; в PROD заменить на LDAP).
+               Формат: <username>=<password>,<role1>,<role2>
+               admin/admin-password — единственный пользователь. -->
+          <param>
+            <name>main.ldapRealm</name>
+            <value>org.apache.shiro.realm.text.IniRealm</value>
+          </param>
+          <param>
+            <name>main.ldapRealm.iniResourcePath</name>
+            <value>classpath:shiro.ini</value>
+          </param>
+          <param>
+            <name>users.admin</name>
+            <value>admin-password,admin</value>
+          </param>
+          <param>
+            <name>main.invalidRequest</name>
+            <value>org.apache.shiro.web.filter.InvalidRequestFilter</value>
+          </param>
+          <param>
+            <name>main.invalidRequest.blockNonAscii</name>
+            <value>true</value>
+          </param>
+          <param>
+            <name>urls./**</name>
+            <value>authcBasic</value>
+          </param>
+        </provider>
+
+        <provider>
+          <role>identity-assertion</role>
+          <name>Default</name>
+          <enabled>true</enabled>
+        </provider>
+
+        <provider>
+          <role>hostmap</role>
+          <name>static</name>
+          <enabled>false</enabled>
+        </provider>
+      </gateway>
+
+      <!-- KNOXSSO service — выдаёт JWT cookie hadoop-jwt после login,
+           проверяет его через /verify endpoint. -->
+      <service>
+        <role>KNOXSSO</role>
+        <param>
+          <name>knoxsso.cookie.name</name>
+          <value>hadoop-jwt</value>
+        </param>
+        <param>
+          <name>knoxsso.cookie.secure.only</name>
+          <value>true</value>
+        </param>
+        <param>
+          <name>knoxsso.cookie.max.age</name>
+          <value>86400</value>
+        </param>
+        <param>
+          <name>knoxsso.token.ttl</name>
+          <value>86400000</value>
+        </param>
+        <!-- Whitelist URL-ов на которые можно редиректить после login.
+             Регex должен покрыть наш Recon hostname. -->
+        <param>
+          <name>knoxsso.redirect.whitelist.regex</name>
+          <value>^https?:\/\/(localhost|127\.0\.0\.1|.*\.{{ .Values.global.ingress.baseDomain | replace "." "\\." }}).*$</value>
+        </param>
+      </service>
+
+      <!-- KNOXAUTH — встроенная login страница Knox.
+           URL: /gateway/sdpozone/knoxauth/login.html -->
+      <service>
+        <role>KNOXAUTH</role>
+      </service>
+
+      <!-- Ozone Recon UI через Knox.
+           Для login/logout flow используется только KNOXSSO выше.
+           Сам RECON service нужен только если хочешь чтобы Knox
+           проксировал HTTP-запросы (для React SPA не работает,
+           поэтому реальный доступ к Recon идёт напрямую через ingress). -->
+      <service>
+        <role>RECON</role>
+        <url>http://{{ include "ozone.recon.fqdn" . }}:{{ .Values.recon.service.port }}</url>
+      </service>
+
+      {{- if .Values.knox.proxy.s3g.enabled }}
+      <service>
+        <role>S3G</role>
+        <url>http://{{ .Values.s3g.serviceName }}-rest.{{ include "ozone.namespace" . }}.svc.{{ .Values.global.clusterDomain }}:{{ .Values.s3g.service.rest.port }}</url>
+      </service>
+      {{- end }}
+    </topology>
+
+  gateway-log4j.properties: |
+    app.log.dir=${KNOX_LOG_DIR}
+    app.log.file=gateway.log
+    log4j.rootLogger=INFO, drfa
+    log4j.appender.drfa=org.apache.log4j.DailyRollingFileAppender
+    log4j.appender.drfa.File=${app.log.dir}/${app.log.file}
+    log4j.appender.drfa.DatePattern=.yyyy-MM-dd
+    log4j.appender.drfa.layout=org.apache.log4j.PatternLayout
+    log4j.appender.drfa.layout.ConversionPattern=%d{ISO8601} %-5p [%t] %c{2} - %m%n
+{{- end }}
diff --git a/helm-charts/ozone/templates/knox/deployment.yaml b/helm-charts/ozone/templates/knox/deployment.yaml
new file mode 100644
index 0000000..73b0ecb
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/deployment.yaml
@@ -0,0 +1,228 @@
+{{- if .Values.knox.enabled }}
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Values.knox.serviceName }}
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+spec:
+  replicas: {{ .Values.knox.replicas }}
+  selector:
+    matchLabels:
+      {{- include "ozone.selectorLabels" . | nindent 6 }}
+      component: {{ .Values.knox.component }}
+  template:
+    metadata:
+      labels:
+        {{- include "ozone.selectorLabels" . | nindent 8 }}
+        {{- include "ozone.secmanLabels" . | nindent 8 }}
+        component: {{ .Values.knox.component }}
+      annotations:
+        checksum/knox-config: {{ include (print $.Template.BasePath "/knox/configmap.yaml") . | sha256sum }}
+        {{- include "ozone.secmanAnnotations" . | nindent 8 }}
+        {{- include "ozone.istioAnnotations" . | nindent 8 }}
+        {{- include "ozone.kerberosAnnotations" (dict "ctx" $ "component" "knox") | nindent 8 }}
+        {{- if and .Values.secman.enabled .Values.knox.secman.masterSecretKey }}
+        vault.hashicorp.com/agent-inject-secret-knox-master-secret: 'true'
+        vault.hashicorp.com/agent-inject-template-knox-master-secret: |
+          {{`{{- with secret `}}"{{ .Values.secman.path }}"{{` -}}`}}
+          {{`{{ .Data.`}}{{ .Values.knox.secman.masterSecretKey }}{{` }}`}}
+          {{`{{- end }}`}}
+        # vault-agent по умолчанию пишет файлы под uid `vault`, наш knox под
+        # uid 10001 — не может читать. agent-run-as-same-user заставляет
+        # vault-agent работать под UID main container-а → файлы становятся
+        # owned by uid 10001 → knox их читает без permission denied.
+        vault.hashicorp.com/agent-run-as-same-user: 'true'
+        vault.hashicorp.com/agent-inject-perms-knox-master-secret: '0440'
+        {{- end }}
+    spec:
+      # Knox-специфичный podSecurityContext (fsGroup=10001, не глобальный 10001 → но runAsUser other).
+      securityContext:
+        {{- toYaml .Values.knox.podSecurityContext | nindent 8 }}
+      serviceAccountName: default
+      {{- with .Values.global.image.pullSecrets }}
+      imagePullSecrets:
+        {{- toYaml . | nindent 8 }}
+      {{- end }}
+      # Логика инициализации master перенесена в main container (не в init).
+      # Причина: Vault Agent init container требует сеть для login в Vault,
+      # а сеть в pod-е проходит через Envoy iptables redirect. Envoy
+      # стартует только в фазе main containers, поэтому в init фазе сеть
+      # ещё не работает → vault-agent-init тайм-аутит. Перенесли всё в
+      # main container, где Envoy уже работает параллельно (как sidecar).
+      containers:
+        {{- if .Values.fluentBit.enabled }}
+        {{- include "ozone.fluentbit.container" (dict "ctx" $ "component" "knox") | nindent 8 }}
+        {{- end }}
+        - name: knox
+          image: "{{ coalesce .Values.knox.image.registry .Values.global.image.registry }}/{{ .Values.knox.image.repository }}:{{ .Values.knox.image.tag }}"
+          imagePullPolicy: Always
+          # Knox-специфичный securityContext: UID/GID 10001 (см. components-knox/docker/Dockerfile).
+          # Глобальный 1000 не работает — /home/knox принадлежит knox:knox.
+          securityContext:
+            {{- toYaml .Values.knox.securityContext | nindent 12 }}
+          ports:
+            - name: gateway
+              containerPort: {{ .Values.knox.service.port }}
+              protocol: TCP
+          # ENTRYPOINT из Dockerfile — `/home/knox/bin/gateway.sh start`.
+          # Переопределяем, чтобы перед стартом gateway создать master через
+          # knoxcli.sh. Это здесь, а не в init container, потому что vault-agent
+          # для login в Vault нуждается в Envoy (iptables redirect от Istio),
+          # а Envoy стартует только в main-containers phase.
+          command:
+            - /bin/sh
+            - -c
+          args:
+            - |
+              set -ux
+              echo "knox: starting init+gateway wrapper"
+              echo "knox: uid=$(id 2>&1)"
+
+              {{- if and .Values.secman.enabled .Values.knox.secman.masterSecretKey }}
+              # secman=true: ждём пока Vault Agent sidecar напишет файл.
+              MASTER_FILE=/vault/secrets/knox-master-secret
+              for i in $(seq 1 60); do
+                  if [ -s "$MASTER_FILE" ]; then break; fi
+                  echo "knox: waiting for $MASTER_FILE ($i/60)"
+                  sleep 2
+              done
+              if [ ! -s "$MASTER_FILE" ]; then
+                  echo "knox: ERROR — $MASTER_FILE not available after 120s"
+                  exit 1
+              fi
+              MASTER=$(cat "$MASTER_FILE")
+              echo "knox: master length from vault = ${#MASTER}"
+              {{- else }}
+              # secman=false: master из values.knox.masterSecret (DEV).
+              MASTER="${KNOX_MASTER_SECRET_VALUE:-}"
+              echo "knox: master length from values = ${#MASTER}"
+              {{- end }}
+
+              if [ -z "$MASTER" ]; then
+                  echo "knox: ERROR — master secret is empty"
+                  exit 1
+              fi
+
+              # /home/knox/data — emptyDir, при рестарте pod-а каждый раз
+              # пустой. Если security/ остался от предыдущего create-master
+              # в этой же pod-жизни (после restart основного процесса) —
+              # удалить, чтобы create-master не упирался.
+              if [ -d /home/knox/data/security ]; then
+                  echo "knox: cleaning stale /home/knox/data/security"
+                  rm -rf /home/knox/data/security
+              fi
+
+              echo "knox: running knoxcli.sh create-master..."
+              /home/knox/bin/knoxcli.sh create-master --master "$MASTER" --force </dev/null
+              KNOX_RC=$?
+              echo "knox: knoxcli.sh exit=$KNOX_RC"
+              if [ "$KNOX_RC" -ne 0 ]; then
+                  echo "knox: create-master failed, aborting"
+                  exit "$KNOX_RC"
+              fi
+              echo "knox: master secret installed, starting gateway"
+
+              # Передаём управление gateway.sh через exec — PID 1 = java,
+              # сигналы (SIGTERM при rolling restart) дойдут до JVM.
+              exec /home/knox/bin/gateway.sh start
+          env:
+            # Heap limit (-Xmx) подобран под knox.resources.limits.memory=1Gi
+            # с запасом для off-heap (Netty buffers, metaspace, etc.) ~256Mi.
+            # Используется и для knoxcli create-master, и для gateway.
+            - name: KNOX_GATEWAY_OPTS
+              value: "-Djava.net.preferIPv4Stack=true -Djava.security.egd=file:/dev/./urandom -Dsecurerandom.source=file:/dev/./urandom -Xms256m -Xmx768m"
+            - name: JAVA_TOOL_OPTIONS
+              value: "-Djava.security.egd=file:/dev/./urandom -Dsecurerandom.source=file:/dev/./urandom -Xms256m -Xmx768m"
+            {{- if not (and .Values.secman.enabled .Values.knox.secman.masterSecretKey) }}
+            - name: KNOX_MASTER_SECRET_VALUE
+              value: {{ .Values.knox.masterSecret | quote }}
+            {{- end }}
+            {{- if .Values.fluentBit.enabled }}
+            - name: KNOX_LOG_DIR
+              value: {{ .Values.fluentBit.logDir | quote }}
+            {{- end }}
+            {{- if .Values.global.security.kerberos.enabled }}
+            - name: KERBEROS_ENABLED
+              value: "true"
+            - name: KERBEROS_PRINCIPAL
+              value: {{ printf "HTTP/%s.%s.svc.%s@%s" .Values.knox.serviceName (include "ozone.namespace" .) .Values.global.clusterDomain .Values.global.security.kerberos.realm | quote }}
+            - name: KERBEROS_KEYTAB_FILE
+              value: {{ printf "%s/knox.keytab" .Values.global.security.kerberos.keytabDir | quote }}
+            - name: KERBEROS_VAULT_B64_FILE
+              value: "/vault/secrets/knox-keytab-b64"
+            - name: KERBEROS_WAIT_TIMEOUT
+              value: {{ .Values.global.security.kerberos.wait.timeout | quote }}
+            - name: KERBEROS_WAIT_INTERVAL
+              value: {{ .Values.global.security.kerberos.wait.interval | quote }}
+            {{- end }}
+          # Knox в образе разложен по /home/knox/ (см. component-knox/docker/Dockerfile).
+          # Конфигурация — в /home/knox/conf/, данные — в /home/knox/data.
+          volumeMounts:
+            - name: knox-config
+              mountPath: /home/knox/conf/gateway-site.xml
+              subPath: gateway-site.xml
+            - name: knox-config
+              mountPath: /home/knox/conf/topologies/sdpozone.xml
+              subPath: sdpozone.xml
+            - name: knox-config
+              mountPath: /home/knox/conf/gateway-log4j.properties
+              subPath: gateway-log4j.properties
+            # Custom service definitions для Ozone — Knox по умолчанию знает
+            # только Hadoop-сервисы. Папка совпадает с gateway.services.dir
+            # из gateway-site.xml. ConfigMap содержит service.xml + rewrite.xml.
+            - name: knox-services-recon
+              mountPath: /home/knox/conf/services/recon/1.0.0
+              readOnly: true
+            - name: knox-data
+              mountPath: /home/knox/data
+            {{- if .Values.fluentBit.enabled }}
+            {{- include "ozone.fluentbit.logsMount" . | nindent 12 }}
+            {{- end }}
+            {{- if .Values.global.security.kerberos.enabled }}
+            - name: keytabs
+              mountPath: {{ .Values.global.security.kerberos.keytabDir }}
+            {{- end }}
+            {{- include "ozone.krb5VolumeMount" . | nindent 12 }}
+          # Увеличенные initialDelaySeconds, т.к. main container теперь сам
+          # делает create-master перед запуском gateway: vault-agent wait (до 120s)
+          # + knoxcli (5-10s) + gateway startup (15-30s). Берём с запасом.
+          livenessProbe:
+            tcpSocket:
+              port: {{ .Values.knox.service.port }}
+            initialDelaySeconds: 180
+            periodSeconds: 15
+            failureThreshold: 5
+          readinessProbe:
+            tcpSocket:
+              port: {{ .Values.knox.service.port }}
+            initialDelaySeconds: 120
+            periodSeconds: 10
+          {{- with .Values.knox.resources }}
+          resources:
+            {{- toYaml . | nindent 12 }}
+          {{- end }}
+      volumes:
+        {{- if .Values.fluentBit.enabled }}
+        {{- include "ozone.fluentbit.volumes" . | nindent 8 }}
+        {{- end }}
+        - name: knox-config
+          configMap:
+            name: {{ include "ozone.fullname" . }}-knox-config
+        - name: knox-services-recon
+          configMap:
+            name: {{ include "ozone.fullname" . }}-knox-services-recon
+        # data-каталог Knox: keystore/truststore/deployments создаются в runtime.
+        # При рестарте pod-а будет сгенерирован новый identity keystore — это OK,
+        # т.к. публикуем TLS на ingress controller (если нужна персистентность —
+        # перенести на PVC).
+        - name: knox-data
+          emptyDir: {}
+        {{- if .Values.global.security.kerberos.enabled }}
+        - name: keytabs
+          emptyDir: {}
+        {{- end }}
+        {{- include "ozone.krb5Volume" . | nindent 8 }}
+{{- end }}
diff --git a/helm-charts/ozone/templates/knox/ingress.yaml b/helm-charts/ozone/templates/knox/ingress.yaml
new file mode 100644
index 0000000..f5abe35
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/ingress.yaml
@@ -0,0 +1,34 @@
+{{- if and .Values.knox.enabled .Values.knox.ingress.enabled }}
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ .Values.knox.serviceName }}
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+  annotations:
+    # Knox принимает HTTPS на 8443 (терминирует TLS сам, с self-signed
+    # cert). Без этой аннотации nginx-ingress пойдёт plain HTTP → 400.
+    nginx.ingress.kubernetes.io/backend-protocol: "HTTPS"
+    {{- with .Values.knox.ingress.annotations }}
+    {{- toYaml . | nindent 4 }}
+    {{- end }}
+spec:
+  ingressClassName: {{ .Values.knox.ingress.className }}
+  {{- with .Values.knox.ingress.tls }}
+  tls:
+    {{- toYaml . | nindent 4 }}
+  {{- end }}
+  rules:
+    - host: {{ include "ozone.ingress.host" (dict "host" .Values.knox.ingress.host "component" .Values.knox.serviceName "ctx" .) }}
+      http:
+        paths:
+          - path: /
+            pathType: Prefix
+            backend:
+              service:
+                name: {{ .Values.knox.serviceName }}
+                port:
+                  number: {{ .Values.knox.service.port }}
+{{- end }}
