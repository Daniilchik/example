diff --git a/helm-charts/ozone/templates/knox/configmap.yaml b/helm-charts/ozone/templates/knox/configmap.yaml
new file mode 100644
index 0000000..2a50cfc
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/configmap.yaml
@@ -0,0 +1,216 @@
+{{- if .Values.knox.enabled }}
+{{/*
+  Конфигурация Knox: gateway-site.xml, log4j и topologies.
+
+  Topology рендерятся по .Values.knox.auth.mode:
+    anonymous (default) — одна sdpozone topology, ShiroProvider=anon.
+    sso                 — две topology:
+                           * sdpozone — SSOCookieProvider, защищает Recon
+                             cookie hadoop-jwt; редирект на login form
+                             при отсутствии валидной cookie.
+                           * knoxsso  — KnoxSSO + IniRealm + knoxauth
+                             (HTML login form, выдаёт JWT после успешного
+                             authcBasic).
+
+  Service definitions (OZONE-RECON, knoxauth) — встроенные в Knox image
+  (data/services и data/applications), мы их НЕ переопределяем.
+*/}}
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: {{ include "ozone.fullname" . }}-knox-config
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+data:
+  {{- if eq .Values.knox.auth.mode "sso" }}
+  # ─── sdpozone: проксирует Recon, защищён SSOCookieProvider ─────────
+  sdpozone.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <topology>
+      <gateway>
+        <provider>
+          <role>federation</role>
+          <name>SSOCookieProvider</name>
+          <enabled>true</enabled>
+          <param>
+            <name>sso.authentication.provider.url</name>
+            <value>https://{{ include "ozone.ingress.host" (dict "host" .Values.recon.ingress.host "component" .Values.recon.serviceName "ctx" .) }}/gateway/knoxsso/api/v1/websso</value>
+          </param>
+        </provider>
+        <provider>
+          <role>identity-assertion</role>
+          <name>Default</name>
+          <enabled>true</enabled>
+        </provider>
+      </gateway>
+      <service>
+        <role>OZONE-RECON</role>
+        <url>http://{{ include "ozone.recon.fqdn" . }}:{{ .Values.recon.service.port }}</url>
+      </service>
+    </topology>
+
+  # ─── knoxsso: login form + IniRealm + KNOXSSO + knoxauth ───────────
+  knoxsso.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <topology>
+      <gateway>
+        <provider>
+          <role>webappsec</role>
+          <name>WebAppSec</name>
+          <enabled>true</enabled>
+          <param>
+            <name>xframe.options.enabled</name>
+            <value>true</value>
+          </param>
+        </provider>
+        <provider>
+          <role>authentication</role>
+          <name>ShiroProvider</name>
+          <enabled>true</enabled>
+          <param>
+            <name>sessionTimeout</name>
+            <value>30</value>
+          </param>
+          <param>
+            <name>redirectToUrl</name>
+            <value>/gateway/knoxsso/knoxauth/login.html</value>
+          </param>
+          {{- range .Values.knox.auth.sso.users }}
+          <!-- user: {{ .username }} (roles: {{ .roles }}) -->
+          <param>
+            <name>users.{{ .username }}</name>
+            <value>{{ .password }},{{ .roles }}</value>
+          </param>
+          <param>
+            <name>roles.{{ .roles }}</name>
+            <value>*</value>
+          </param>
+          {{- end }}
+          <!-- ВАЖНО: порядок urls имеет значение в Shiro.
+               /knoxauth/** — anon (статика login form, иначе бесконечный
+               редирект). /api/v1/websso идёт через basic auth, чтобы JWT
+               получил sub=<user>, а не sub=anonymous. -->
+          <param>
+            <name>urls./knoxauth/**</name>
+            <value>anon</value>
+          </param>
+          <param>
+            <name>urls./**</name>
+            <value>authcBasic</value>
+          </param>
+        </provider>
+        <provider>
+          <role>identity-assertion</role>
+          <name>Default</name>
+          <enabled>true</enabled>
+        </provider>
+      </gateway>
+      <service>
+        <role>KNOXSSO</role>
+        <param>
+          <name>knoxsso.cookie.secure.only</name>
+          <value>true</value>
+        </param>
+        <param>
+          <name>knoxsso.token.ttl</name>
+          <value>{{ int .Values.knox.auth.sso.cookieTtl }}</value>
+        </param>
+        <param>
+          <name>knoxsso.redirect.whitelist.regex</name>
+          <value>{{ include "ozone.knox.sso.whitelistRegex" . }}</value>
+        </param>
+      </service>
+      <!-- knoxauth — это application, не service. Сам ставится из
+           data/applications/knoxauth/ в Knox image (login.html и т.п.) -->
+      <application>
+        <name>knoxauth</name>
+      </application>
+    </topology>
+  {{- else }}
+  # ─── anonymous: всё пропускаем (smoke-test mode) ───────────────────
+  sdpozone.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <topology>
+      <gateway>
+        <provider>
+          <role>authentication</role>
+          <name>ShiroProvider</name>
+          <enabled>true</enabled>
+          <param>
+            <name>sessionTimeout</name>
+            <value>30</value>
+          </param>
+          <param>
+            <name>urls./**</name>
+            <value>anon</value>
+          </param>
+        </provider>
+        <provider>
+          <role>identity-assertion</role>
+          <name>Default</name>
+          <enabled>true</enabled>
+        </provider>
+      </gateway>
+      <service>
+        <role>OZONE-RECON</role>
+        <url>http://{{ include "ozone.recon.fqdn" . }}:{{ .Values.recon.service.port }}</url>
+      </service>
+    </topology>
+  {{- end }}
+
+  # ─── Override built-in OZONE-RECON service ────────────────────────
+  # Knox HTML response rewriter обрезает webpack-сборку Recon HTML
+  # (truncate inline <script> с chunk manifest, теряются последние
+  # <script src=>). Workaround: переопределяем service.xml/rewrite.xml
+  # без OUT-rule, чтобы Knox прокидывал HTML без модификаций.
+  #
+  # Браузер получает оригинальные пути `/static/js/...`, `/api/v1/...`
+  # и обращается через ingress `/` route напрямую к Recon (тот же hostname).
+  ozone-recon-service.xml: |
+    <service role="OZONE-RECON" name="ozone-recon" version="1.2.0">
+        <metadata>
+            <type>UI</type>
+            <context>/ozone-recon/index.html</context>
+            <shortDesc>OZONE Recon UI (pass-through, no body rewrite)</shortDesc>
+        </metadata>
+        <routes>
+            <route path="/ozone-recon"/>
+            <route path="/ozone-recon/**"/>
+        </routes>
+    </service>
+  ozone-recon-rewrite.xml: |
+    <rules>
+        <rule dir="IN" name="OZONE-RECON/rule/inbound" pattern="*://*:*/**/ozone-recon/{recon_path=**}?{**}">
+            <rewrite template="{$serviceUrl[OZONE-RECON]}/{recon_path=**}?{**}"/>
+        </rule>
+    </rules>
+
+  gateway-site.xml: |
+    <?xml version="1.0" encoding="UTF-8"?>
+    <configuration>
+      <property>
+        <name>gateway.port</name>
+        <value>{{ .Values.knox.service.port }}</value>
+      </property>
+      <property>
+        <name>gateway.path</name>
+        <value>gateway</value>
+      </property>
+    </configuration>
+
+  gateway-log4j.properties: |
+    app.log.dir=${KNOX_LOG_DIR}
+    app.log.file=gateway.log
+    log4j.rootLogger=INFO, drfa
+    log4j.appender.drfa=org.apache.log4j.DailyRollingFileAppender
+    log4j.appender.drfa.File=${app.log.dir}/${app.log.file}
+    log4j.appender.drfa.DatePattern=.yyyy-MM-dd
+    log4j.appender.drfa.layout=org.apache.log4j.PatternLayout
+    log4j.appender.drfa.layout.ConversionPattern=%d{ISO8601} %-5p [%t] %c{2} - %m%n
+    # DEBUG для диагностики dispatch к backend Recon
+    log4j.logger.org.apache.knox.gateway.dispatch=DEBUG
+    log4j.logger.org.apache.knox.gateway.deploy=DEBUG
+    log4j.logger.org.apache.http.wire=INFO
+{{- end }}
diff --git a/helm-charts/ozone/templates/knox/deployment.yaml b/helm-charts/ozone/templates/knox/deployment.yaml
new file mode 100644
index 0000000..e67c9d3
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/deployment.yaml
@@ -0,0 +1,151 @@
+{{- if .Values.knox.enabled }}
+{{/*
+  Минимальный deployment Knox — запускаем из коробки.
+  Custom topology, service definitions, dispatchers — НЕ переопределяем.
+  Только: master secret из Vault + минимальный gateway-site.xml.
+*/}}
+apiVersion: apps/v1
+kind: Deployment
+metadata:
+  name: {{ .Values.knox.serviceName }}
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+spec:
+  replicas: {{ .Values.knox.replicas }}
+  selector:
+    matchLabels:
+      {{- include "ozone.selectorLabels" . | nindent 6 }}
+      component: {{ .Values.knox.component }}
+  template:
+    metadata:
+      labels:
+        {{- include "ozone.selectorLabels" . | nindent 8 }}
+        {{- include "ozone.secmanLabels" . | nindent 8 }}
+        component: {{ .Values.knox.component }}
+      annotations:
+        checksum/knox-config: {{ include (print $.Template.BasePath "/knox/configmap.yaml") . | sha256sum }}
+        {{- include "ozone.secmanAnnotations" . | nindent 8 }}
+        {{- include "ozone.istioAnnotations" . | nindent 8 }}
+        vault.hashicorp.com/agent-inject-secret-knox-master-secret: 'true'
+        vault.hashicorp.com/agent-inject-template-knox-master-secret: |
+          {{`{{- with secret `}}"{{ .Values.secman.path }}"{{` -}}`}}
+          {{`{{ .Data.`}}{{ .Values.knox.secman.masterSecretKey }}{{` }}`}}
+          {{`{{- end }}`}}
+        vault.hashicorp.com/agent-run-as-same-user: 'true'
+        vault.hashicorp.com/agent-inject-perms-knox-master-secret: '0440'
+    spec:
+      securityContext:
+        {{- toYaml .Values.knox.podSecurityContext | nindent 8 }}
+      serviceAccountName: default
+      {{- with .Values.global.image.pullSecrets }}
+      imagePullSecrets:
+        {{- toYaml . | nindent 8 }}
+      {{- end }}
+      containers:
+        - name: knox
+          image: "{{ coalesce .Values.knox.image.registry .Values.global.image.registry }}/{{ .Values.knox.image.repository }}:{{ .Values.knox.image.tag }}"
+          imagePullPolicy: Always
+          securityContext:
+            {{- toYaml .Values.knox.securityContext | nindent 12 }}
+          ports:
+            - name: gateway
+              containerPort: {{ .Values.knox.service.port }}
+              protocol: TCP
+          # Перед запуском gateway создаём master из Vault.
+          command:
+            - /bin/sh
+            - -c
+          args:
+            - |
+              set -ux
+              MASTER_FILE=/vault/secrets/knox-master-secret
+              for i in $(seq 1 60); do
+                  [ -s "$MASTER_FILE" ] && break
+                  echo "knox: waiting for $MASTER_FILE ($i/60)"
+                  sleep 2
+              done
+              [ -s "$MASTER_FILE" ] || { echo "knox: master not available"; exit 1; }
+              MASTER=$(cat "$MASTER_FILE")
+              if [ -d /home/knox/data/security ]; then
+                  rm -rf /home/knox/data/security
+              fi
+              /home/knox/bin/knoxcli.sh create-master --master "$MASTER" --force </dev/null
+              exec /home/knox/bin/gateway.sh start
+          env:
+            - name: KNOX_GATEWAY_OPTS
+              value: "-Djava.net.preferIPv4Stack=true -Djava.security.egd=file:/dev/./urandom -Xms256m -Xmx768m"
+            - name: JAVA_TOOL_OPTIONS
+              value: "-Djava.security.egd=file:/dev/./urandom -Xms256m -Xmx768m"
+            {{- if .Values.fluentBit.enabled }}
+            - name: KNOX_LOG_DIR
+              value: {{ .Values.fluentBit.logDir | quote }}
+            {{- end }}
+          # Mount-ы:
+          # - gateway-site.xml + log4j (наши настройки)
+          # - topologies/sdpozone.xml [+ knoxsso.xml в sso mode]
+          # - data/services/ozone-recon/1.2.0/* — override built-in,
+          #   отключает HTML response body rewriter (workaround truncation
+          #   webpack-сборки Recon)
+          # - data/security + data/deployments (writable места Knox)
+          volumeMounts:
+            - name: knox-config
+              mountPath: /home/knox/conf/gateway-site.xml
+              subPath: gateway-site.xml
+            - name: knox-config
+              mountPath: /home/knox/conf/topologies/sdpozone.xml
+              subPath: sdpozone.xml
+            {{- if eq .Values.knox.auth.mode "sso" }}
+            # SSO mode добавляет knoxsso topology с login form.
+            # Перекрываем дефолтную knoxsso.xml из image (которая LDAP-based)
+            # нашей INI-realm версией.
+            - name: knox-config
+              mountPath: /home/knox/conf/topologies/knoxsso.xml
+              subPath: knoxsso.xml
+            {{- end }}
+            # Override built-in OZONE-RECON service definition — без OUT-rewrite
+            # Knox не модифицирует response body → не обрезает webpack HTML.
+            - name: knox-config
+              mountPath: /home/knox/data/services/ozone-recon/1.2.0/service.xml
+              subPath: ozone-recon-service.xml
+            - name: knox-config
+              mountPath: /home/knox/data/services/ozone-recon/1.2.0/rewrite.xml
+              subPath: ozone-recon-rewrite.xml
+            - name: knox-config
+              mountPath: /home/knox/conf/gateway-log4j.properties
+              subPath: gateway-log4j.properties
+            - name: knox-data-security
+              mountPath: /home/knox/data/security
+            - name: knox-data-deployments
+              mountPath: /home/knox/data/deployments
+            {{- if .Values.fluentBit.enabled }}
+            {{- include "ozone.fluentbit.logsMount" . | nindent 12 }}
+            {{- end }}
+          livenessProbe:
+            tcpSocket:
+              port: {{ .Values.knox.service.port }}
+            initialDelaySeconds: 120
+            periodSeconds: 15
+            failureThreshold: 5
+          readinessProbe:
+            tcpSocket:
+              port: {{ .Values.knox.service.port }}
+            initialDelaySeconds: 60
+            periodSeconds: 10
+          {{- with .Values.knox.resources }}
+          resources:
+            {{- toYaml . | nindent 12 }}
+          {{- end }}
+      volumes:
+        {{- if .Values.fluentBit.enabled }}
+        {{- include "ozone.fluentbit.volumes" . | nindent 8 }}
+        {{- end }}
+        - name: knox-config
+          configMap:
+            name: {{ include "ozone.fullname" . }}-knox-config
+        - name: knox-data-security
+          emptyDir: {}
+        - name: knox-data-deployments
+          emptyDir: {}
+{{- end }}
diff --git a/helm-charts/ozone/templates/knox/ingress.yaml b/helm-charts/ozone/templates/knox/ingress.yaml
new file mode 100644
index 0000000..f5abe35
--- /dev/null
+++ b/helm-charts/ozone/templates/knox/ingress.yaml
@@ -0,0 +1,34 @@
+{{- if and .Values.knox.enabled .Values.knox.ingress.enabled }}
+apiVersion: networking.k8s.io/v1
+kind: Ingress
+metadata:
+  name: {{ .Values.knox.serviceName }}
+  namespace: {{ include "ozone.namespace" . }}
+  labels:
+    {{- include "ozone.labels" . | nindent 4 }}
+    app.kubernetes.io/component: ozone-knox
+  annotations:
+    # Knox принимает HTTPS на 8443 (терминирует TLS сам, с self-signed
+    # cert). Без этой аннотации nginx-ingress пойдёт plain HTTP → 400.
+    nginx.ingress.kubernetes.io/backend-protocol: "HTTPS"
+    {{- with .Values.knox.ingress.annotations }}
+    {{- toYaml . | nindent 4 }}
+    {{- end }}
+spec:
+  ingressClassName: {{ .Values.knox.ingress.className }}
+  {{- with .Values.knox.ingress.tls }}
+  tls:
+    {{- toYaml . | nindent 4 }}
+  {{- end }}
+  rules:
+    - host: {{ include "ozone.ingress.host" (dict "host" .Values.knox.ingress.host "component" .Values.knox.serviceName "ctx" .) }}
+      http:
+        paths:
+          - path: /
+            pathType: Prefix
+            backend:
+              service:
+                name: {{ .Values.knox.serviceName }}
+                port:
+                  number: {{ .Values.knox.service.port }}
+{{- end }}
