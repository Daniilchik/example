diff --git a/helm-charts/ozone/templates/_helpers.tpl b/helm-charts/ozone/templates/_helpers.tpl
index cd6b111..3363cb9 100644
--- a/helm-charts/ozone/templates/_helpers.tpl
+++ b/helm-charts/ozone/templates/_helpers.tpl
@@ -144,6 +144,32 @@ securityContext:
 {{- end }}
 {{- end -}}
 
+{{/*
+Writable /tmp volume mount — required for every container when
+global.securityContext.readOnlyRootFilesystem is true. Hadoop/Ozone/Java write
+under /tmp by default: Ranger policy cache, ozone.http.basedir, Netty/JNA
+native libs, JVM heap dumps, FluentBit tail-DB files.
+
+Usage: {{- include "ozone.writableTmpMount" $ | nindent 12 }}
+*/}}
+{{- define "ozone.writableTmpMount" -}}
+- name: tmp
+  mountPath: /tmp
+{{- end -}}
+
+{{/*
+Companion volume for ozone.writableTmpMount. Uses tmpfs (medium: Memory) so
+short-lived files don't hit the node disk and are wiped on pod restart.
+
+Usage: {{- include "ozone.writableTmpVolume" $ | nindent 8 }}
+*/}}
+{{- define "ozone.writableTmpVolume" -}}
+- name: tmp
+  emptyDir:
+    medium: Memory
+    sizeLimit: 256Mi
+{{- end -}}
+
 {{/*
 Istio sidecar injection annotation.
 Outputs sidecar.istio.io/inject: "true" when istio.enabled and istio.injection.enabled are both true.
